<!-- Loading Spinner -->
<div id="loadingSpinner" class="loading-overlay" style="display: none;">
    <div class="loading-spinner">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Yükleniyor...</span>
        </div>
        <p class="mt-3 text-muted">İşleminiz gerçekleştiriliyor, lütfen bekleyin...</p>
    </div>
</div>

<style>
    .loading-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .loading-spinner {
        background: white;
        padding: 2rem;
        border-radius: 12px;
        text-align: center;
        box-shadow: 0 10px 40px rgba(0,0,0,0.2);
    }
</style>

<script>
    (function () {
        function hideGlobalSpinner() {
            const spinner = document.getElementById('loadingSpinner');
            if (spinner) {
                spinner.style.display = 'none';
            }
        }

        /** jQuery unobtrusive novalidate kullandığı için checkValidity() yeterli de değil */
        function formPassesClientValidation(form) {
            if (window.jQuery) {
                var $form = window.jQuery(form);
                if ($form.data('validator')) {
                    return $form.valid();
                }
            }
            return form.checkValidity();
        }

        function fetchArgLooksLikeSearchLocation(arg) {
            if (typeof arg === 'string') {
                return arg.indexOf('SearchLocation') !== -1;
            }
            if (typeof Request !== 'undefined' && arg instanceof Request) {
                return arg.url.indexOf('SearchLocation') !== -1;
            }
            return false;
        }

        window.addEventListener('pageshow', hideGlobalSpinner);

        document.addEventListener('DOMContentLoaded', function() {
            hideGlobalSpinner();

            document.querySelectorAll('form').forEach(function (form) {
                form.addEventListener('submit', function () {
                    if (!formPassesClientValidation(form)) {
                        return;
                    }
                    const spinner = document.getElementById('loadingSpinner');
                    if (spinner) {
                        spinner.style.display = 'flex';
                    }
                });
            });

            const originalFetch = window.fetch;
            window.fetch = function () {
                const spinner = document.getElementById('loadingSpinner');
                const first = arguments[0];
                const skipSpinner = fetchArgLooksLikeSearchLocation(first);
                if (spinner && !skipSpinner) {
                    spinner.style.display = 'flex';
                }
                return originalFetch.apply(this, arguments).finally(function () {
                    hideGlobalSpinner();
                });
            };
        });
    })();
</script>

