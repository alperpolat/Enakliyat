<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    
    <style>
        :root {
            --sidebar-width: 260px;
            --header-height: 64px;
            --primary-color: #4f46e5;
            --primary-light: #818cf8;
            --primary-dark: #3730a3;
            --sidebar-bg: #1e1e2d;
            --sidebar-hover: #2a2a3c;
            --text-muted: #a1a5b7;
        }
        
        * {
            font-family: 'Inter', sans-serif;
        }
        
        body {
            background: #f5f8fa;
            min-height: 100vh;
        }
        
        /* Sidebar */
        .admin-sidebar {
            position: fixed;
            left: 0;
            top: 0;
            bottom: 0;
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            z-index: 1050;
            display: flex;
            flex-direction: column;
            transition: transform 0.3s;
        }
        
        .sidebar-header {
            height: var(--header-height);
            display: flex;
            align-items: center;
            padding: 0 1.5rem;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        
        .sidebar-logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            text-decoration: none;
        }
        
        .sidebar-logo-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 1.25rem;
        }
        
        .sidebar-logo-text {
            font-size: 1.25rem;
            font-weight: 800;
            color: #fff;
        }
        
        .sidebar-logo-text span {
            color: var(--primary-light);
        }
        
        .sidebar-menu {
            flex: 1;
            overflow-y: auto;
            padding: 1rem 0;
        }
        
        .menu-section {
            padding: 0.5rem 1.5rem;
            margin-top: 1rem;
        }
        
        .menu-section-title {
            font-size: 0.6875rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
            font-weight: 700;
        }
        
        .menu-item {
            display: flex;
            align-items: center;
            gap: 0.875rem;
            padding: 0.75rem 1.5rem;
            color: rgba(255,255,255,0.7);
            text-decoration: none;
            transition: all 0.2s;
            border-left: 3px solid transparent;
            font-size: 0.9375rem;
            font-weight: 500;
        }
        
        .menu-item:hover {
            background: var(--sidebar-hover);
            color: #fff;
        }
        
        .menu-item.active {
            background: rgba(79,70,229,0.15);
            color: var(--primary-light);
            border-left-color: var(--primary-color);
        }
        
        .menu-item i {
            width: 20px;
            font-size: 1rem;
            opacity: 0.8;
        }
        
        .menu-item .badge {
            margin-left: auto;
            font-size: 0.6875rem;
            padding: 0.25rem 0.5rem;
            font-weight: 600;
        }
        
        .sidebar-footer {
            padding: 1rem 1.5rem;
            border-top: 1px solid rgba(255,255,255,0.05);
        }
        
        .sidebar-user {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem;
            background: var(--sidebar-hover);
            border-radius: 10px;
        }
        
        .sidebar-user-avatar {
            width: 40px;
            height: 40px;
            background: var(--primary-color);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 700;
        }
        
        .sidebar-user-info {
            flex: 1;
            min-width: 0;
        }
        
        .sidebar-user-name {
            color: #fff;
            font-weight: 600;
            font-size: 0.875rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        
        .sidebar-user-role {
            color: var(--text-muted);
            font-size: 0.75rem;
        }
        
        /* Main Content */
        .admin-main {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        
        .admin-header {
            height: var(--header-height);
            background: #fff;
            border-bottom: 1px solid #e1e3ea;
            display: flex;
            align-items: center;
            padding: 0 1.5rem;
            position: sticky;
            top: 0;
            z-index: 1040;
        }
        
        .admin-header-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: #181c32;
            margin: 0;
        }
        
        .admin-header-actions {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        
        .header-icon-btn {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: #f5f8fa;
            border: none;
            color: #7e8299;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            transition: all 0.2s;
            position: relative;
        }
        
        .header-icon-btn:hover {
            background: #eff2f5;
            color: var(--primary-color);
        }
        
        .header-icon-btn .badge-dot {
            position: absolute;
            top: 8px;
            right: 8px;
            width: 8px;
            height: 8px;
            background: #f1416c;
            border-radius: 50%;
            border: 2px solid #fff;
        }
        
        .admin-content {
            flex: 1;
            padding: 1.5rem;
        }
        
        /* Cards */
        .admin-card {
            background: #fff;
            border-radius: 12px;
            border: none;
            box-shadow: 0 0 20px rgba(0,0,0,0.02);
        }
        
        .admin-card-header {
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid #eff2f5;
            display: flex;
            align-items: center;
        }
        
        .admin-card-title {
            font-size: 1rem;
            font-weight: 700;
            color: #181c32;
            margin: 0;
        }
        
        .admin-card-body {
            padding: 1.5rem;
        }
        
        /* Stats Cards */
        .stat-card {
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
            border-radius: 12px;
            padding: 1.5rem;
            color: #fff;
        }
        
        .stat-card.orange {
            background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
        }
        
        .stat-card.teal {
            background: linear-gradient(135deg, #14b8a6 0%, #0d9488 100%);
        }
        
        .stat-card.pink {
            background: linear-gradient(135deg, #ec4899 0%, #be185d 100%);
        }
        
        .stat-card-icon {
            width: 48px;
            height: 48px;
            background: rgba(255,255,255,0.2);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            margin-bottom: 1rem;
        }
        
        .stat-card-value {
            font-size: 1.75rem;
            font-weight: 800;
            margin-bottom: 0.25rem;
        }
        
        .stat-card-label {
            font-size: 0.875rem;
            opacity: 0.8;
        }
        
        /* Tables */
        .admin-table {
            margin: 0;
        }
        
        .admin-table thead th {
            background: #f5f8fa;
            border: none;
            padding: 0.875rem 1rem;
            font-size: 0.8125rem;
            font-weight: 600;
            color: #7e8299;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .admin-table tbody td {
            padding: 1rem;
            vertical-align: middle;
            border-color: #eff2f5;
            color: #5e6278;
        }
        
        .admin-table tbody tr:hover {
            background: #f9f9f9;
        }
        
        /* Buttons */
        .btn-admin-primary {
            background: var(--primary-color);
            color: #fff;
            border: none;
            padding: 0.625rem 1.25rem;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.875rem;
            transition: all 0.2s;
        }
        
        .btn-admin-primary:hover {
            background: var(--primary-dark);
            color: #fff;
            transform: translateY(-1px);
        }
        
        .btn-admin-light {
            background: #f5f8fa;
            color: #5e6278;
            border: none;
            padding: 0.625rem 1.25rem;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.875rem;
            transition: all 0.2s;
        }
        
        .btn-admin-light:hover {
            background: #eff2f5;
            color: var(--primary-color);
        }
        
        /* Mobile */
        .sidebar-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 1.25rem;
            color: #5e6278;
            margin-right: 1rem;
        }
        
        @@media (max-width: 991.98px) {
            .admin-sidebar {
                transform: translateX(-100%);
            }
            
            .admin-sidebar.show {
                transform: translateX(0);
            }
            
            .admin-main {
                margin-left: 0;
            }
            
            .sidebar-toggle {
                display: block;
            }
            
            .sidebar-overlay {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: rgba(0,0,0,0.5);
                z-index: 1049;
                display: none;
            }
            
            .sidebar-overlay.show {
                display: block;
            }
        }
    </style>
</head>
<body>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    
    <!-- Sidebar -->
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="sidebar-header">
            <a href="@Url.Action("Dashboard", "Admin")" class="sidebar-logo">
                <div class="sidebar-logo-icon">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <span class="sidebar-logo-text">Admin<span>Panel</span></span>
            </a>
        </div>
        
        <nav class="sidebar-menu">
            <div class="menu-section">
                <div class="menu-section-title">Ana Menü</div>
            </div>
            <a href="@Url.Action("Dashboard", "Admin")" class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
                <i class="fas fa-home"></i>
                <span>Dashboard</span>
            </a>
            
            <div class="menu-section">
                <div class="menu-section-title">Yönetim</div>
            </div>
            <a href="@Url.Action("Requests", "Admin")" class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Requests" ? "active" : "")">
                <i class="fas fa-inbox"></i>
                <span>Talepler</span>
            </a>
            <a href="@Url.Action("Carriers", "Admin")" class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Carriers" ? "active" : "")">
                <i class="fas fa-truck"></i>
                <span>Nakliyeciler</span>
                @if (ViewBag.PendingCarrierApprovals != null && ViewBag.PendingCarrierApprovals > 0)
                {
                    <span class="badge bg-warning text-dark">@ViewBag.PendingCarrierApprovals</span>
                }
            </a>
            <a href="@Url.Action("Users", "Admin")" class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")">
                <i class="fas fa-users"></i>
                <span>Kullanıcılar</span>
            </a>
            <a href="@Url.Action("Reviews", "Admin")" class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Reviews" ? "active" : "")">
                <i class="fas fa-star"></i>
                <span>Değerlendirmeler</span>
            </a>
            
            <div class="menu-section">
                <div class="menu-section-title">Bildirimler</div>
            </div>
            <a href="@Url.Action("Notifications", "Admin")" class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Notifications" || ViewContext.RouteData.Values["action"]?.ToString() == "NotificationTemplate" ? "active" : "")">
                <i class="fas fa-bell"></i>
                <span>Bildirim Şablonları</span>
            </a>
            <a href="@Url.Action("CarrierDocuments", "Admin")" class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "CarrierDocuments" ? "active" : "")">
                <i class="fas fa-file-check"></i>
                <span>Firma Belgeleri</span>
            </a>
            
            <div class="menu-section">
                <div class="menu-section-title">Finans</div>
            </div>
            <a href="@Url.Action("Commissions", "Admin")" class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Commissions" ? "active" : "")">
                <i class="fas fa-percent"></i>
                <span>Komisyon Yönetimi</span>
            </a>
            <a href="@Url.Action("FinancialReports", "Admin")" class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "FinancialReports" ? "active" : "")">
                <i class="fas fa-chart-line"></i>
                <span>Finansal Raporlar</span>
            </a>
            
            <div class="menu-section">
                <div class="menu-section-title">İşlemler</div>
            </div>
            <a href="@Url.Action("BulkOperations", "Admin")" class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "BulkOperations" ? "active" : "")">
                <i class="fas fa-tasks"></i>
                <span>Toplu İşlemler</span>
            </a>
            <a href="@Url.Action("ExportRequests", "Admin")" class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "ExportRequests" ? "active" : "")">
                <i class="fas fa-file-export"></i>
                <span>Raporlama/Export</span>
            </a>
            <a href="@Url.Action("ActivityLogs", "Admin")" class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "ActivityLogs" ? "active" : "")">
                <i class="fas fa-history"></i>
                <span>Log/Audit Trail</span>
            </a>
            
            <div class="menu-section">
                <div class="menu-section-title">Ayarlar</div>
            </div>
            <a href="@Url.Action("Settings", "Admin")" class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Settings" || ViewContext.RouteData.Values["action"]?.ToString() == "CreateSetting" ? "active" : "")">
                <i class="fas fa-cog"></i>
                <span>Sistem Ayarları</span>
            </a>
            <a href="@Url.Action("AddOnServices", "Admin")" class="menu-item @(ViewContext.RouteData.Values["action"]?.ToString() == "AddOnServices" ? "active" : "")">
                <i class="fas fa-plus-circle"></i>
                <span>Ek Hizmetler</span>
            </a>
        </nav>
        
        <div class="sidebar-footer">
            <div class="sidebar-user">
                <div class="sidebar-user-avatar">
                    A
                </div>
                <div class="sidebar-user-info">
                    <div class="sidebar-user-name">@User.Identity?.Name</div>
                    <div class="sidebar-user-role">Sistem Yöneticisi</div>
                </div>
            </div>
            <form asp-controller="Account" asp-action="Logout" method="post" class="mt-2">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-admin-light w-100">
                    <i class="fas fa-sign-out-alt me-2"></i>Çıkış Yap
                </button>
            </form>
        </div>
    </aside>
    
    <!-- Main Content -->
    <main class="admin-main">
        <header class="admin-header">
            <button class="sidebar-toggle" id="sidebarToggle">
                <i class="fas fa-bars"></i>
            </button>
            <h1 class="admin-header-title">@ViewData["Title"]</h1>
            <div class="admin-header-actions">
                <button class="header-icon-btn">
                    <i class="fas fa-bell"></i>
                    <span class="badge-dot"></span>
                </button>
                <a href="@Url.Action("Index", "Home")" class="header-icon-btn" title="Siteye Git">
                    <i class="fas fa-external-link-alt"></i>
                </a>
            </div>
        </header>
        
        <div class="admin-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: 10px; border: none;">
                    <i class="fas fa-check-circle me-2"></i>
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: 10px; border: none;">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            
            @RenderBody()
        </div>
    </main>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('sidebarToggle')?.addEventListener('click', function() {
            document.getElementById('adminSidebar').classList.toggle('show');
            document.getElementById('sidebarOverlay').classList.toggle('show');
        });
        
        document.getElementById('sidebarOverlay')?.addEventListener('click', function() {
            document.getElementById('adminSidebar').classList.remove('show');
            this.classList.remove('show');
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

