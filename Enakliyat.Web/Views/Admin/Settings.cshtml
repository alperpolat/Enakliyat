@model List<Enakliyat.Domain.SystemSetting>
@{
    ViewData["Title"] = "Sistem Ayarları";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Sistem Ayarları</h2>
    <a href="@Url.Action("CreateSetting", "Admin")" class="btn btn-admin-primary">
        <i class="fas fa-plus me-2"></i>Yeni Ayar
    </a>
</div>

@foreach (var category in ViewBag.Categories as List<string> ?? new List<string>())
{
    <div class="admin-card mb-4">
        <div class="admin-card-header">
            <h3 class="admin-card-title">@category</h3>
        </div>
        <div class="admin-card-body">
            <div class="table-responsive">
                <table class="table admin-table">
                    <thead>
                        <tr>
                            <th>Anahtar</th>
                            <th>Değer</th>
                            <th>Açıklama</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var setting in Model.Where(s => s.Category == category))
                        {
                            <tr>
                                <td><strong>@setting.Key</strong></td>
                                <td>
                                    @if (setting.IsEncrypted)
                                    {
                                        <span class="text-muted">••••••••</span>
                                    }
                                    else
                                    {
                                        <span>@(setting.Value ?? "-")</span>
                                    }
                                </td>
                                <td>@(setting.Description ?? "-")</td>
                                <td>
                                    <button class="btn btn-sm btn-admin-light" onclick="editSetting(@setting.Id, '@setting.Key', '@(setting.Value?.Replace("'", "\\'") ?? "")', @setting.IsEncrypted.ToString().ToLower())">
                                        <i class="fas fa-edit"></i> Düzenle
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<!-- Edit Modal -->
<div class="modal fade" id="editSettingModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Ayar Düzenle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editSettingForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" id="settingId" name="id" />
                    <div class="mb-3">
                        <label class="form-label">Anahtar</label>
                        <input type="text" id="settingKey" class="form-control" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Değer</label>
                        <input type="text" id="settingValue" name="value" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-admin-primary">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function editSetting(id, key, value, isEncrypted) {
            document.getElementById('settingId').value = id;
            document.getElementById('settingKey').value = key;
            document.getElementById('settingValue').value = isEncrypted ? '' : value;
            document.getElementById('editSettingForm').action = '@Url.Action("UpdateSetting", "Admin")?id=' + id;
            new bootstrap.Modal(document.getElementById('editSettingModal')).show();
        }
    </script>
}

