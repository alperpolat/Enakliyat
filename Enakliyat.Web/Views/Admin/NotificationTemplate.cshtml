@model Enakliyat.Domain.NotificationTemplate
@{
    ViewData["Title"] = Model.Id == 0 ? "Yeni Bildirim Şablonu" : "Bildirim Şablonu Düzenle";
}

<div class="admin-card">
    <div class="admin-card-header">
        <h3 class="admin-card-title">@ViewData["Title"]</h3>
    </div>
    <div class="admin-card-body">
        <form asp-action="NotificationTemplate" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            
            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label">Şablon Adı *</label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Type" class="form-label">Tip *</label>
                    <select asp-for="Type" class="form-select" required>
                        <option value="Email">Email</option>
                        <option value="SMS">SMS</option>
                    </select>
                    <span asp-validation-for="Type" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="EventType" class="form-label">Olay Tipi *</label>
                    <select asp-for="EventType" class="form-select" required>
                        <option value="NewRequest">Yeni Talep</option>
                        <option value="NewOffer">Yeni Teklif</option>
                        <option value="OfferAccepted">Teklif Kabul Edildi</option>
                        <option value="OfferRejected">Teklif Reddedildi</option>
                        <option value="ReservationStatusChanged">Rezervasyon Durumu Değişti</option>
                        <option value="PaymentReceived">Ödeme Alındı</option>
                    </select>
                    <span asp-validation-for="EventType" class="text-danger"></span>
                </div>
            </div>
            
            <div class="mb-3">
                <label asp-for="Subject" class="form-label">Konu *</label>
                <input asp-for="Subject" class="form-control" required />
                <small class="text-muted">Kullanılabilir değişkenler: {RequestId}, {CustomerName}, {CarrierName}, {Price}, vb.</small>
                <span asp-validation-for="Subject" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Body" class="form-label">İçerik *</label>
                <textarea asp-for="Body" class="form-control" rows="10" required></textarea>
                <small class="text-muted">HTML formatında yazabilirsiniz. Değişkenler için {RequestId}, {CustomerName} gibi format kullanın.</small>
                <span asp-validation-for="Body" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Variables" class="form-label">Kullanılabilir Değişkenler (JSON)</label>
                <textarea asp-for="Variables" class="form-control" rows="3" placeholder='{"RequestId": "Talep No", "CustomerName": "Müşteri Adı", ...}'></textarea>
                <small class="text-muted">Bu şablon için kullanılabilir değişkenlerin açıklaması (JSON formatında)</small>
            </div>
            
            <div class="mb-3 form-check">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label asp-for="IsActive" class="form-check-label">Aktif</label>
            </div>
            
            <div class="d-flex justify-content-end gap-2">
                <a href="@Url.Action("Notifications", "Admin")" class="btn btn-admin-light">İptal</a>
                <button type="submit" class="btn btn-admin-primary">Kaydet</button>
            </div>
        </form>
    </div>
</div>

