@model IEnumerable<Enakliyat.Domain.AddOnService>

@{
    ViewData["Title"] = "Admin - Ek Hizmetler";
}

<div class="container py-4">
    <h3 class="mb-3">Ek Hizmetler</h3>

    <form asp-action="CreateAddOnService" method="post" class="row g-2 mb-4">
        @Html.AntiForgeryToken()
        <div class="col-md-3">
            <input name="name" class="form-control" placeholder="Hizmet adı (örn. Paketleme)" required />
        </div>
        <div class="col-md-3">
            <div class="input-group">
                <input name="defaultPrice" type="number" step="0.01" class="form-control" placeholder="Varsayılan fiyat" />
                <span class="input-group-text">TL</span>
            </div>
        </div>
        <div class="col-md-3">
            <select name="pricingType" class="form-select">
                <option value="Fixed">Sabit Ücret</option>
                <option value="Percentage">Yüzde</option>
                <option value="Included">Dahil</option>
            </select>
        </div>
        <div class="col-md-2">
            <div class="form-check mt-1">
                <input class="form-check-input" type="checkbox" name="isActive" value="true" checked id="isActiveCheck" />
                <label class="form-check-label" for="isActiveCheck">Aktif</label>
            </div>
        </div>
        <div class="col-md-1 d-grid">
            <button type="submit" class="btn btn-primary btn-sm">Ekle</button>
        </div>
    </form>

    <table class="table table-striped table-hover table-sm align-middle">
        <thead>
            <tr>
                <th>#</th>
                <th>Ad</th>
                <th>Fiyat</th>
                <th>Fiyat Tipi</th>
                <th>Durum</th>
            </tr>
        </thead>
        <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="5" class="text-center">Henüz ek hizmet tanımlı değil.</td>
            </tr>
        }
        else
        {
            var index = 1;
            foreach (var s in Model)
            {
                <tr>
                    <td>@index</td>
                    <td>@s.Name</td>
                    <td>@(s.DefaultPrice.HasValue ? s.DefaultPrice.Value.ToString("N2") + " TL" : "-")</td>
                    <td>@s.PricingType</td>
                    <td>@(s.IsActive ? "Aktif" : "Pasif")</td>
                </tr>
                index++;
            }
        }
        </tbody>
    </table>
</div>
