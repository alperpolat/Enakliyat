@model Enakliyat.Web.Models.AdminRequestDetailsViewModel

@{
    ViewData["Title"] = "Admin - Talep Detayı";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-1">Talep #@Model.Request.Id</h3>
            <div class="text-muted small">
                @(Model.Request.User?.Email ?? "Anonim") · @Model.Request.CreatedAt.ToLocalTime().ToString("g")
            </div>
        </div>
        <div>
            <a asp-action="Requests" class="btn btn-sm btn-outline-secondary">← Taleplere dön</a>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h5 class="card-title mb-3">İş Bilgileri</h5>
                    <dl class="row small mb-0">
                        <dt class="col-4">Durum</dt>
                        <dd class="col-8 mb-1">@Model.Request.Status</dd>
                        <dt class="col-4">Taşıma Tipi</dt>
                        <dd class="col-8 mb-1">@Model.Request.MoveType</dd>
                        <dt class="col-4">Tarih</dt>
                        <dd class="col-8 mb-1">@MoveDateFormatting.ToTurkishRangeDisplay(Model.Request.MoveDate.ToLocalTime(), Model.Request.MoveDateEnd?.ToLocalTime())</dd>
                        <dt class="col-4">Müşteri Adı</dt>
                        <dd class="col-8 mb-1">@Model.Request.CustomerName</dd>
                        <dt class="col-4">Telefon</dt>
                        <dd class="col-8 mb-1">@Model.Request.PhoneNumber</dd>
                        <dt class="col-4">E-posta</dt>
                        <dd class="col-8 mb-1">@(string.IsNullOrWhiteSpace(Model.Request.Email) ? "—" : Model.Request.Email)</dd>
                        <dt class="col-4">Oda tipi</dt>
                        <dd class="col-8 mb-1">@(string.IsNullOrWhiteSpace(Model.Request.RoomType) ? "—" : Model.Request.RoomType)</dd>
                        <dt class="col-4">Çıkış katı</dt>
                        <dd class="col-8 mb-1">@(Model.Request.FromFloor.HasValue ? Model.Request.FromFloor.Value.ToString() : "—")</dd>
                        <dt class="col-4">Varış katı</dt>
                        <dd class="col-8 mb-1">@(Model.Request.ToFloor.HasValue ? Model.Request.ToFloor.Value.ToString() : "—")</dd>
                        <dt class="col-4">Çıkışta asansör</dt>
                        <dd class="col-8 mb-1">@(Model.Request.FromHasElevator ? "Evet" : "Hayır")</dd>
                        <dt class="col-4">Varışta asansör</dt>
                        <dd class="col-8 mb-1">@(Model.Request.ToHasElevator ? "Evet" : "Hayır")</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h5 class="card-title mb-3">Adres Bilgileri</h5>
                    <dl class="row small mb-0">
                        <dt class="col-4">Nereden</dt>
                        <dd class="col-8 mb-1">@Model.Request.FromAddress</dd>
                        <dt class="col-4">Nereye</dt>
                        <dd class="col-8 mb-1">@Model.Request.ToAddress</dd>
                    </dl>
                </div>
            </div>
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h5 class="card-title mb-2">Ek hizmetler</h5>
                    @if (!Model.SecilenEkHizmetler.Any())
                    {
                        <div class="small text-muted mb-0">Seçilen ek hizmet yok.</div>
                    }
                    else
                    {
                        <ul class="small mb-0 ps-3">
                            @foreach (var ad in Model.SecilenEkHizmetler)
                            {
                                <li>@ad</li>
                            }
                        </ul>
                    }
                </div>
            </div>
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-2">Notlar</h5>
                    <div class="small text-muted">@(string.IsNullOrWhiteSpace(Model.Request.Notes) ? "—" : Model.Request.Notes)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h5 class="card-title mb-3">Talep fotoğrafları</h5>
            @if (!Model.Photos.Any())
            {
                <div class="small text-muted mb-0">Bu talep için yüklenmiş fotoğraf yok.</div>
            }
            else
            {
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var photo in Model.Photos)
                    {
                        <a href="@photo.FilePath" target="_blank" rel="noopener" class="border rounded bg-body d-block" style="width: 160px; height: 160px; overflow: hidden;">
                            <img src="@photo.FilePath" alt="Talep fotoğrafı" class="img-fluid w-100 h-100 object-fit-cover" />
                        </a>
                    }
                </div>
            }
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-body">
            <h5 class="card-title mb-0">Teklifler</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Firma</th>
                            <th>Oluşturma</th>
                            <th>Teklif</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (!Model.Offers.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-3 small">Bu talep için henüz teklif yok.</td>
                        </tr>
                    }
                    else
                    {
                        var index = 1;
                        foreach (var o in Model.Offers)
                        {
                            <tr>
                                <td>@index</td>
                                <td>@o.Carrier?.Name</td>
                                <td>@o.CreatedAt.ToLocalTime().ToString("g")</td>
                                <td>@o.Price.ToString("N0") TL</td>
                                <td>@o.Status</td>
                            </tr>
                            index++;
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
