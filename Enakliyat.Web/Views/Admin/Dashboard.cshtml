@{ 
    ViewData["Title"] = "Dashboard";
}

<div class="row g-4 mb-4">
    <!-- Stats Row 1 -->
    <div class="col-lg-3 col-md-6">
        <div class="stat-card">
            <div class="stat-card-icon">
                <i class="fas fa-inbox"></i>
            </div>
            <div class="stat-card-value">@ViewBag.TotalRequests</div>
            <div class="stat-card-label">Toplam Talep</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="stat-card orange">
            <div class="stat-card-icon">
                <i class="fas fa-users"></i>
            </div>
            <div class="stat-card-value">@ViewBag.TotalUsers</div>
            <div class="stat-card-label">Toplam Kullanıcı</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="stat-card teal">
            <div class="stat-card-icon">
                <i class="fas fa-truck"></i>
            </div>
            <div class="stat-card-value">@ViewBag.TotalCarriers</div>
            <div class="stat-card-label">Toplam Nakliyeci</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="stat-card pink">
            <div class="stat-card-icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="stat-card-value">@ViewBag.CompletedRequests</div>
            <div class="stat-card-label">Tamamlanan</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Left Column -->
    <div class="col-xl-8">
        <!-- Quick Stats -->
        <div class="admin-card mb-4">
            <div class="admin-card-header">
                <h3 class="admin-card-title">Haftalık Özet</h3>
            </div>
            <div class="admin-card-body">
                <div class="row g-4">
                    <div class="col-md-3 col-6">
                        <div class="d-flex align-items-center">
                            <div class="me-3" style="width: 48px; height: 48px; background: #e0f2fe; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-file-alt text-primary"></i>
                            </div>
                            <div>
                                <div class="fw-bold fs-4">@ViewBag.NewRequestsWeek</div>
                                <div class="text-muted small">Yeni Talep</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="d-flex align-items-center">
                            <div class="me-3" style="width: 48px; height: 48px; background: #dcfce7; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-user-plus text-success"></i>
                            </div>
                            <div>
                                <div class="fw-bold fs-4">@ViewBag.NewUsersWeek</div>
                                <div class="text-muted small">Yeni Kullanıcı</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="d-flex align-items-center">
                            <div class="me-3" style="width: 48px; height: 48px; background: #fef3c7; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-hand-holding-usd text-warning"></i>
                            </div>
                            <div>
                                <div class="fw-bold fs-4">@ViewBag.WeeklyDepositCount</div>
                                <div class="text-muted small">Kapora Ödeme</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="d-flex align-items-center">
                            <div class="me-3" style="width: 48px; height: 48px; background: #fce7f3; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-lira-sign text-danger"></i>
                            </div>
                            <div>
                                <div class="fw-bold fs-4">@ViewBag.WeeklyDepositAmount?.ToString("N0") ₺</div>
                                <div class="text-muted small">Haftalık Gelir</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Charts -->
        <div class="admin-card mb-4">
            <div class="admin-card-header">
                <h3 class="admin-card-title">Son 30 Günlük Trend</h3>
            </div>
            <div class="admin-card-body">
                <canvas id="trendChart" style="max-height: 300px;"></canvas>
            </div>
        </div>
        
        <!-- Status Overview -->
        <div class="admin-card">
            <div class="admin-card-header">
                <h3 class="admin-card-title">Durum Özeti</h3>
            </div>
            <div class="admin-card-body">
                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="p-3 rounded-3" style="background: #f0fdf4; border-left: 4px solid #22c55e;">
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-clock text-success me-2"></i>
                                <span class="text-muted small">Açık Teklifler</span>
                            </div>
                            <div class="fw-bold fs-3 text-success">@ViewBag.OpenOffers</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 rounded-3" style="background: #eff6ff; border-left: 4px solid #3b82f6;">
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-calendar-check text-primary me-2"></i>
                                <span class="text-muted small">Aktif Rezervasyon</span>
                            </div>
                            <div class="fw-bold fs-3 text-primary">@ViewBag.ActiveReservations</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 rounded-3" style="background: #fef3c7; border-left: 4px solid #f59e0b;">
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-hourglass-half text-warning me-2"></i>
                                <span class="text-muted small">Bekleyen Firma Onayı</span>
                            </div>
                            <div class="fw-bold fs-3 text-warning">@ViewBag.PendingCarrierApprovals</div>
                        </div>
                    </div>
                </div>
                
                <hr class="my-4">
                
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <div class="mb-3 mb-md-0">
                            <div class="text-muted small mb-1">İptal Oranı</div>
                            <div class="d-flex align-items-center">
                                <div class="progress flex-grow-1" style="height: 8px; border-radius: 4px;">
                                    <div class="progress-bar bg-danger" style="width: @((double)ViewBag.CancelRate * 100)%;"></div>
                                </div>
                                <span class="ms-3 fw-bold">@(((double)ViewBag.CancelRate * 100d).ToString("0.1"))%</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div>
                            <div class="text-muted small mb-1">Ortalama Firma Puanı</div>
                            <div class="d-flex align-items-center">
                                <i class="fas fa-star text-warning me-2"></i>
                                <span class="fw-bold fs-4">@(((double)ViewBag.AverageCarrierRating).ToString("0.0"))</span>
                                <span class="text-muted ms-1">/ 5</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Right Column -->
    <div class="col-xl-4">
        <!-- Revenue Card -->
        <div class="admin-card mb-4">
            <div class="admin-card-header">
                <h3 class="admin-card-title">Gelir Özeti</h3>
            </div>
            <div class="admin-card-body">
                <div class="text-center py-3">
                    <div class="mb-3">
                        <div class="d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px; background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%); border-radius: 50%;">
                            <i class="fas fa-lira-sign text-white fs-1"></i>
                        </div>
                    </div>
                    <div class="text-muted small mb-1">Bugünkü Gelir</div>
                    <div class="fw-bold fs-2 text-success mb-3">@ViewBag.TodayRevenue?.ToString("N0") ₺</div>
                    
                    <hr>
                    
                    <div class="text-muted small mb-1">Bu Ayki Toplam</div>
                    <div class="fw-bold fs-4">@ViewBag.MonthRevenue?.ToString("N0") ₺</div>
                </div>
            </div>
        </div>
        
        <!-- Quick Actions -->
        <div class="admin-card">
            <div class="admin-card-header">
                <h3 class="admin-card-title">Hızlı İşlemler</h3>
            </div>
            <div class="admin-card-body">
                <div class="d-grid gap-2">
                    <a href="@Url.Action("Requests", "Admin")" class="btn btn-admin-light text-start">
                        <i class="fas fa-inbox me-2"></i>Talepleri Görüntüle
                    </a>
                    <a href="@Url.Action("Carriers", "Admin", new { status = "Pending" })" class="btn btn-admin-light text-start">
                        <i class="fas fa-user-check me-2"></i>Bekleyen Onaylar
                        @if (ViewBag.PendingCarrierApprovals != null && ViewBag.PendingCarrierApprovals > 0)
                        {
                            <span class="badge bg-warning text-dark float-end">@ViewBag.PendingCarrierApprovals</span>
                        }
                    </a>
                    <a href="@Url.Action("Reviews", "Admin")" class="btn btn-admin-light text-start">
                        <i class="fas fa-star me-2"></i>Değerlendirmeler
                    </a>
                    <a href="@Url.Action("AddOnServices", "Admin")" class="btn btn-admin-light text-start">
                        <i class="fas fa-cog me-2"></i>Ek Hizmetler
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        // Trend Chart
        const ctx = document.getElementById('trendChart');
        if (ctx) {
            const labels = @Html.Raw(Json.Serialize(ViewBag.ChartLabels ?? new List<string>()));
            const requestsData = @Html.Raw(Json.Serialize(ViewBag.RequestsChartData ?? new List<int>()));
            const paymentsData = @Html.Raw(Json.Serialize(ViewBag.PaymentsChartData ?? new List<double>()));

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'Talepler',
                            data: requestsData,
                            borderColor: '#4f46e5',
                            backgroundColor: 'rgba(79, 70, 229, 0.1)',
                            tension: 0.4,
                            fill: true
                        },
                        {
                            label: 'Gelir (₺)',
                            data: paymentsData,
                            borderColor: '#22c55e',
                            backgroundColor: 'rgba(34, 197, 94, 0.1)',
                            tension: 0.4,
                            fill: true,
                            yAxisID: 'y1'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: {
                            position: 'top',
                        },
                        tooltip: {
                            mode: 'index',
                            intersect: false,
                            callbacks: {
                                label: function(context) {
                                    if (context.datasetIndex === 1) {
                                        return context.dataset.label + ': ' + context.parsed.y.toLocaleString('tr-TR') + ' ₺';
                                    }
                                    return context.dataset.label + ': ' + context.parsed.y;
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            type: 'linear',
                            display: true,
                            position: 'left',
                            title: {
                                display: true,
                                text: 'Talep Sayısı'
                            }
                        },
                        y1: {
                            type: 'linear',
                            display: true,
                            position: 'right',
                            title: {
                                display: true,
                                text: 'Gelir (₺)'
                            },
                            grid: {
                                drawOnChartArea: false,
                            },
                        }
                    }
                }
            });
        }
    </script>
}
