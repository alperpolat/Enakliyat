@model List<Enakliyat.Domain.Carrier>
@{
    ViewData["Title"] = "Komisyon Yönetimi";
}

<div class="admin-card mb-4">
    <div class="admin-card-header">
        <h3 class="admin-card-title">Varsayılan Komisyon Oranı: %@ViewBag.DefaultCommissionRate</h3>
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-body">
        <div class="table-responsive">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>Firma Adı</th>
                        <th>Komisyon Oranı (%)</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var carrier in Model)
                    {
                        <tr>
                            <td><strong>@carrier.Name</strong></td>
                            <td>
                                <form asp-action="UpdateCarrierCommission" method="post" class="d-inline-flex gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="carrierId" value="@carrier.Id" />
                                    <input type="number" name="commissionRate" step="0.01" min="0" max="100" 
                                           value="@ViewBag.DefaultCommissionRate" class="form-control form-control-sm" style="width: 100px;" required />
                                    <button type="submit" class="btn btn-sm btn-admin-primary">Güncelle</button>
                                </form>
                            </td>
                            <td>
                                <span class="badge bg-success">Aktif</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

