@model Enakliyat.Domain.SystemSetting
@{
    ViewData["Title"] = "Yeni Sistem Ayarı";
}

<div class="admin-card">
    <div class="admin-card-header">
        <h3 class="admin-card-title">Yeni Sistem Ayarı</h3>
    </div>
    <div class="admin-card-body">
        <form asp-action="CreateSetting" method="post">
            @Html.AntiForgeryToken()
            
            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Key" class="form-label">Anahtar *</label>
                    <input asp-for="Key" class="form-control" required />
                    <span asp-validation-for="Key" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Category" class="form-label">Kategori *</label>
                    <select asp-for="Category" class="form-select" required>
                        <option value="General">Genel</option>
                        <option value="Email">Email</option>
                        <option value="SMS">SMS</option>
                        <option value="Commission">Komisyon</option>
                        <option value="Payment">Ödeme</option>
                        <option value="Log">Log</option>
                    </select>
                    <span asp-validation-for="Category" class="text-danger"></span>
                </div>
            </div>
            
            <div class="mb-3">
                <label asp-for="Value" class="form-label">Değer</label>
                <input asp-for="Value" class="form-control" />
                <span asp-validation-for="Value" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Description" class="form-label">Açıklama</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            
            <div class="mb-3 form-check">
                <input asp-for="IsEncrypted" class="form-check-input" type="checkbox" />
                <label asp-for="IsEncrypted" class="form-check-label">Şifreli (Şifre, API Key vb.)</label>
            </div>
            
            <div class="d-flex justify-content-end gap-2">
                <a href="@Url.Action("Settings", "Admin")" class="btn btn-admin-light">İptal</a>
                <button type="submit" class="btn btn-admin-primary">Kaydet</button>
            </div>
        </form>
    </div>
</div>

