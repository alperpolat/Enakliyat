@model List<Enakliyat.Domain.SystemSetting>
@{
    ViewData["Title"] = "Aktivite Logları";
}

<div class="admin-card mb-4">
    <div class="admin-card-header">
        <h3 class="admin-card-title">Aktivite Logları</h3>
    </div>
    <div class="admin-card-body">
        <form method="get" class="row g-3 mb-4">
            <div class="col-md-4">
                <label class="form-label">Başlangıç Tarihi</label>
                <input type="date" name="startDate" value="@ViewBag.StartDate.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Bitiş Tarihi</label>
                <input type="date" name="endDate" value="@ViewBag.EndDate.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-admin-primary w-100">Filtrele</button>
            </div>
        </form>
        
        <div class="table-responsive">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>Tarih</th>
                        <th>Anahtar</th>
                        <th>Değer</th>
                        <th>Açıklama</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var log in Model)
                        {
                            <tr>
                                <td>@log.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                <td><strong>@log.Key</strong></td>
                                <td>@(log.Value ?? "-")</td>
                                <td>@(log.Description ?? "-")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                Log bulunamadı.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

