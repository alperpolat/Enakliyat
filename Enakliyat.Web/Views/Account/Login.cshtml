@{
    ViewData["Title"] = "Giriş Yap";
    Layout = "_Layout";
}

<style>
    .auth-section {
        min-height: calc(100vh - 80px);
        display: flex;
        align-items: center;
        background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
        padding: 3rem 0;
    }
    
    .auth-container {
        display: flex;
        background: #fff;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 25px 80px rgba(0,0,0,0.1);
        max-width: 1000px;
        margin: 0 auto;
    }
    
    .auth-image {
        flex: 1;
        background: linear-gradient(135deg, #0052CC 0%, #0747A6 100%);
        padding: 3rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }
    
    .auth-image::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -50%;
        width: 100%;
        height: 100%;
        background: rgba(255,255,255,0.05);
        border-radius: 50%;
    }
    
    .auth-image-content {
        position: relative;
        z-index: 2;
    }
    
    .auth-image h2 {
        font-size: 2rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 1rem;
    }
    
    .auth-image p {
        color: rgba(255,255,255,0.8);
        font-size: 1.1rem;
        line-height: 1.7;
        margin-bottom: 2rem;
    }
    
    .auth-features {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    
    .auth-features li {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: rgba(255,255,255,0.9);
        margin-bottom: 0.75rem;
        font-size: 0.95rem;
    }
    
    .auth-features li i {
        color: #4ADE80;
        font-size: 0.875rem;
    }
    
    .auth-form {
        flex: 1;
        padding: 3rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    
    .auth-logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 2rem;
    }
    
    .auth-logo-icon {
        width: 45px;
        height: 45px;
        background: linear-gradient(135deg, #0052CC 0%, #4C9AFF 100%);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.25rem;
    }
    
    .auth-logo-text {
        font-size: 1.5rem;
        font-weight: 800;
        color: #1e293b;
    }
    
    .auth-logo-text span {
        color: #0052CC;
    }
    
    .auth-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 0.5rem;
    }
    
    .auth-subtitle {
        color: #64748b;
        margin-bottom: 2rem;
    }
    
    .form-label-custom {
        font-weight: 600;
        color: #1e293b;
        margin-bottom: 0.5rem;
    }
    
    .form-control-custom {
        padding: 0.875rem 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        font-size: 1rem;
        transition: all 0.3s;
        background: #f8fafc;
    }
    
    .form-control-custom:focus {
        border-color: #0052CC;
        background: #fff;
        box-shadow: 0 0 0 4px rgba(0,82,204,0.1);
    }
    
    .btn-auth-primary {
        width: 100%;
        padding: 0.875rem;
        background: linear-gradient(135deg, #0052CC 0%, #4C9AFF 100%);
        border: none;
        border-radius: 10px;
        color: #fff;
        font-size: 1rem;
        font-weight: 700;
        transition: all 0.3s;
    }
    
    .btn-auth-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(0,82,204,0.3);
        color: #fff;
    }
    
    .btn-auth-google {
        width: 100%;
        padding: 0.875rem;
        background: #fff;
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        color: #1e293b;
        font-size: 1rem;
        font-weight: 600;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
    }
    
    .btn-auth-google:hover {
        border-color: #0052CC;
        background: #f8fafc;
    }
    
    .btn-auth-google img {
        width: 20px;
        height: 20px;
    }
    
    .auth-divider {
        display: flex;
        align-items: center;
        margin: 1.5rem 0;
    }
    
    .auth-divider::before,
    .auth-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #e2e8f0;
    }
    
    .auth-divider span {
        padding: 0 1rem;
        color: #94a3b8;
        font-size: 0.875rem;
    }
    
    .auth-footer {
        text-align: center;
        margin-top: 2rem;
        color: #64748b;
    }
    
    .auth-footer a {
        color: #0052CC;
        font-weight: 600;
        text-decoration: none;
    }
    
    .auth-footer a:hover {
        text-decoration: underline;
    }
    
    .alert-auth {
        border: none;
        border-radius: 10px;
        padding: 1rem;
        margin-bottom: 1.5rem;
    }
    
    @@media (max-width: 991.98px) {
        .auth-image {
            display: none;
        }
        
        .auth-form {
            padding: 2rem;
        }
    }
</style>

<section class="auth-section">
    <div class="container">
        <div class="auth-container">
            <div class="auth-image">
                <div class="auth-image-content">
                    <h2>Hoş Geldiniz!</h2>
                    <p>
                        Türkiye'nin en güvenilir nakliyat platformuna giriş yapın. 
                        Taşınma taleplerinizi yönetin, teklifleri karşılaştırın.
                    </p>
                    <ul class="auth-features">
                        <li><i class="fas fa-check-circle"></i> 81 ilden 1000+ onaylı firma</li>
                        <li><i class="fas fa-check-circle"></i> Ücretsiz teklif alma</li>
                        <li><i class="fas fa-check-circle"></i> Sigortalı taşıma garantisi</li>
                        <li><i class="fas fa-check-circle"></i> %100 güvenli ödeme</li>
                    </ul>
                </div>
            </div>
            
            <div class="auth-form">
                <div class="auth-logo">
                    <div class="auth-logo-icon">
                        <i class="fas fa-truck-moving"></i>
                    </div>
                    <span class="auth-logo-text">Road of <span>Home</span></span>
                </div>
                
                <h1 class="auth-title">Giriş Yap</h1>
                <p class="auth-subtitle">Hesabınıza giriş yaparak devam edin</p>
                
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger alert-auth">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        @Html.ValidationSummary()
                    </div>
                }
                
                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-3">
                        <label class="form-label form-label-custom" for="email">E-posta Adresi</label>
                        <input type="email" id="email" name="email" class="form-control form-control-custom" placeholder="ornek@email.com" required />
                    </div>
                    
                    <div class="mb-4">
                        <label class="form-label form-label-custom" for="password">Şifre</label>
                        <input type="password" id="password" name="password" class="form-control form-control-custom" placeholder="••••••••" required />
                    </div>
                    
                    <button type="submit" class="btn btn-auth-primary">
                        <i class="fas fa-sign-in-alt me-2"></i>
                        Giriş Yap
                    </button>
                </form>
                
                <div class="auth-divider">
                    <span>veya</span>
                </div>
                
                <a asp-action="GoogleLogin" asp-controller="Account" class="btn-auth-google">
                    <svg width="20" height="20" viewBox="0 0 24 24">
                        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                    </svg>
                    Google ile Giriş Yap
                </a>
                
                <div class="auth-footer">
                    <p class="mb-2">Hesabınız yok mu? <a asp-action="Register">Kayıt Ol</a></p>
                    <p class="mb-0"><a asp-controller="CarrierAccount" asp-action="Login">Firma Girişi</a></p>
                </div>
            </div>
        </div>
    </div>
</section>
