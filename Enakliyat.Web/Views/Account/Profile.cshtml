@model Enakliyat.Web.Models.UserProfileViewModel

@{
    ViewData["Title"] = "Profilim";
}

<div class="container py-4">
    <h3 class="mb-3">Profilim</h3>

    <div class="row">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <form asp-action="Profile" method="post" class="small">
                        @Html.AntiForgeryToken()
                        <div class="mb-2">
                            <label class="form-label form-label-sm" asp-for="Name">İsim</label>
                            <input asp-for="Name" class="form-control form-control-sm" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label form-label-sm" asp-for="PhoneNumber">Telefon</label>
                            <input asp-for="PhoneNumber" class="form-control form-control-sm" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label form-label-sm" asp-for="Email">E-posta</label>
                            <input asp-for="Email" class="form-control form-control-sm" />
                        </div>
                        <button type="submit" class="btn btn-sm btn-primary">Güncelle</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
