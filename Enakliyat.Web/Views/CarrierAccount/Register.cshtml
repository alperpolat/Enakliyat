@{
    ViewData["Title"] = "Firma Başvurusu";
    Layout = "_Layout";
}

<style>
    .carrier-register-section {
        min-height: 100vh;
        background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
        padding: 3rem 0;
        position: relative;
        overflow: hidden;
    }
    
    .carrier-register-section::before {
        content: '';
        position: absolute;
        top: -30%;
        left: -20%;
        width: 60%;
        height: 100%;
        background: linear-gradient(135deg, rgba(249,115,22,0.12) 0%, transparent 60%);
        border-radius: 50%;
    }
    
    .carrier-register-header {
        text-align: center;
        margin-bottom: 3rem;
        position: relative;
        z-index: 2;
    }
    
    .carrier-register-header h1 {
        font-size: 2.5rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 0.5rem;
    }
    
    .carrier-register-header p {
        color: rgba(255,255,255,0.7);
        font-size: 1.1rem;
    }
    
    .carrier-register-card {
        background: #fff;
        border-radius: 24px;
        box-shadow: 0 25px 100px rgba(0,0,0,0.3);
        padding: 3rem;
        position: relative;
        z-index: 2;
    }
    
    .carrier-register-logo {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        margin-bottom: 2rem;
    }
    
    .carrier-register-logo-icon {
        width: 56px;
        height: 56px;
        background: linear-gradient(135deg, #f97316 0%, #fb923c 100%);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.75rem;
    }
    
    .carrier-register-logo-text {
        font-size: 1.75rem;
        font-weight: 800;
        color: #1e293b;
    }
    
    .carrier-register-logo-text span {
        color: #f97316;
    }
    
    .section-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid #f1f5f9;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    
    .section-title i {
        color: #f97316;
    }
    
    .form-label-custom {
        font-weight: 600;
        color: #334155;
        margin-bottom: 0.5rem;
        font-size: 0.9375rem;
    }
    
    .form-control-custom {
        padding: 0.75rem 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        font-size: 1rem;
        transition: all 0.3s;
        background: #f8fafc;
    }
    
    .form-control-custom:focus {
        border-color: #f97316;
        background: #fff;
        box-shadow: 0 0 0 4px rgba(249,115,22,0.1);
    }
    
    .form-control-custom::placeholder {
        color: #94a3b8;
    }
    
    .btn-carrier-submit {
        padding: 1rem 2rem;
        background: linear-gradient(135deg, #f97316 0%, #fb923c 100%);
        border: none;
        border-radius: 12px;
        color: #fff;
        font-size: 1.125rem;
        font-weight: 700;
        transition: all 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
    }
    
    .btn-carrier-submit:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 35px rgba(249,115,22,0.35);
        color: #fff;
    }
    
    .file-upload-area {
        border: 2px dashed #e2e8f0;
        border-radius: 12px;
        padding: 2rem;
        text-align: center;
        background: #f8fafc;
        transition: all 0.3s;
        cursor: pointer;
    }
    
    .file-upload-area:hover {
        border-color: #f97316;
        background: #fff9f5;
    }
    
    .file-upload-area i {
        font-size: 2.5rem;
        color: #cbd5e1;
        margin-bottom: 1rem;
    }
    
    .file-upload-area p {
        margin: 0;
        color: #64748b;
    }
    
    .file-upload-area .btn-link {
        color: #f97316;
        font-weight: 600;
        text-decoration: none;
    }
    
    .requirements-box {
        background: linear-gradient(135deg, #eff6ff 0%, #f0f9ff 100%);
        border-radius: 12px;
        padding: 1.5rem;
        border-left: 4px solid #3b82f6;
    }
    
    .requirements-box h5 {
        font-size: 1rem;
        font-weight: 700;
        color: #1e40af;
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .requirements-box ul {
        margin: 0;
        padding-left: 1.25rem;
        color: #475569;
    }
    
    .requirements-box li {
        margin-bottom: 0.25rem;
        font-size: 0.875rem;
    }
    
    .benefits-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }
    
    .benefit-item {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
    }
    
    .benefit-icon {
        width: 48px;
        height: 48px;
        min-width: 48px;
        background: linear-gradient(135deg, rgba(249,115,22,0.15) 0%, rgba(249,115,22,0.05) 100%);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #f97316;
        font-size: 1.25rem;
    }
    
    .benefit-text h6 {
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 0.25rem;
        font-size: 0.9375rem;
    }
    
    .benefit-text p {
        font-size: 0.8125rem;
        color: #64748b;
        margin: 0;
    }
    
    .alert-custom {
        border-radius: 12px;
        border: none;
    }
    
    @@media (max-width: 767.98px) {
        .carrier-register-card {
            padding: 1.5rem;
        }
        
        .carrier-register-header h1 {
            font-size: 1.75rem;
        }
    }
</style>

<section class="carrier-register-section">
    <div class="container">
        <div class="carrier-register-header">
            <h1>Firmamızı Kayıt Et</h1>
            <p>Road of Home iş ortağı olun, müşteri kitlenizi büyütün</p>
        </div>
        
    <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="carrier-register-card">
                    <div class="carrier-register-logo">
                        <div class="carrier-register-logo-icon">
                            <i class="fas fa-truck-moving"></i>
                        </div>
                        <span class="carrier-register-logo-text">Road of <span>Home</span></span>
                    </div>
                    
                    <!-- Benefits -->
                    <div class="benefits-grid">
                        <div class="benefit-item">
                            <div class="benefit-icon">
                                <i class="fas fa-bullhorn"></i>
                            </div>
                            <div class="benefit-text">
                                <h6>Yeni Müşteriler</h6>
                                <p>Günlük yüzlerce taşınma talebi</p>
                            </div>
                        </div>
                        <div class="benefit-item">
                            <div class="benefit-icon">
                                <i class="fas fa-hand-holding-usd"></i>
                            </div>
                            <div class="benefit-text">
                                <h6>Ücretsiz Başvuru</h6>
                                <p>Sadece iş aldığınızda komisyon</p>
                            </div>
                        </div>
                        <div class="benefit-item">
                            <div class="benefit-icon">
                                <i class="fas fa-shield-alt"></i>
                            </div>
                            <div class="benefit-text">
                                <h6>Güvenli Ödeme</h6>
                                <p>Garantili kapora sistemi</p>
                            </div>
                        </div>
                        <div class="benefit-item">
                            <div class="benefit-icon">
                                <i class="fas fa-chart-line"></i>
                            </div>
                            <div class="benefit-text">
                                <h6>İş Takibi</h6>
                                <p>Gelişmiş yönetim paneli</p>
                            </div>
                        </div>
                    </div>
                    
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger alert-custom mb-4">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            @Html.ValidationSummary()
                        </div>
                    }
                    
            <form asp-action="Register" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                        
                        <div class="section-title">
                            <i class="fas fa-building"></i>
                            Firma Bilgileri
                        </div>
                        
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label form-label-custom">Firma Adı *</label>
                                <input name="companyName" class="form-control form-control-custom" placeholder="Örn: ABC Nakliyat Ltd. Şti." required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label form-label-custom">Yetkili Ad Soyad *</label>
                                <input name="name" class="form-control form-control-custom" placeholder="Ad Soyad" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label form-label-custom">Cep Telefonu *</label>
                                <input name="phoneNumber" class="form-control form-control-custom" placeholder="0532 xxx xx xx" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label form-label-custom">Firma Sabit Telefon</label>
                                <input name="landlinePhone" class="form-control form-control-custom" placeholder="0212 xxx xx xx" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label form-label-custom">E-posta Adresi (Giriş için) *</label>
                                <input type="email" name="email" class="form-control form-control-custom" placeholder="firma@email.com" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label form-label-custom">Firma İnternet Sitesi</label>
                                <input type="url" name="website" class="form-control form-control-custom" placeholder="https://www.firma.com" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label form-label-custom">Firmanın Bulunduğu İlçe</label>
                                <select name="districtId" class="form-select form-control-custom">
                                    <option value="">İlçe Seçiniz</option>
                                    @if (ViewBag.Districts != null)
                                    {
                                        foreach (var district in (List<Enakliyat.Domain.District>)ViewBag.Districts)
                                        {
                                            if (district.City != null)
                                            {
                                                <option value="@district.Id">@district.Name / @district.City.Name</option>
                                            }
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label form-label-custom">Yetki Belge Numarası</label>
                                <input name="licenseNumber" class="form-control form-control-custom" placeholder="K1, K2, C2 vb." />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label form-label-custom">Şifre *</label>
                                <input type="password" name="password" id="password" class="form-control form-control-custom" placeholder="En az 6 karakter" required minlength="6" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label form-label-custom">Şifre Tekrar *</label>
                                <input type="password" name="passwordConfirm" id="passwordConfirm" class="form-control form-control-custom" placeholder="Şifrenizi tekrar girin" required />
                            </div>
                        </div>
                        
                        <div class="section-title">
                            <i class="fas fa-truck"></i>
                            Hizmet Bilgileri
                        </div>
                        
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label form-label-custom">Araç / Kapasite Bilgisi</label>
                                <input name="vehicleInfo" class="form-control form-control-custom" placeholder="Örn: 2 adet kapalı kasa kamyon" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label form-label-custom">Hizmet Verilen Bölgeler</label>
                                <input name="serviceAreas" class="form-control form-control-custom" placeholder="Örn: İstanbul, Ankara, Türkiye geneli" />
                            </div>
                            <div class="col-12">
                                <label class="form-label form-label-custom">Firma Hakkında Kısa Açıklama</label>
                                <textarea name="description" class="form-control form-control-custom" rows="3" placeholder="Firmanızın tecrübesi, sunduğu hizmetler ve öne çıkan özellikleri hakkında bilgi verin..."></textarea>
                            </div>
                </div>
                        
                        <div class="section-title">
                            <i class="fas fa-receipt"></i>
                            Fatura Bilgileri
                        </div>
                        
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label form-label-custom">Şirket Ünvanı / Kişi Adı</label>
                                <input name="companyName" class="form-control form-control-custom" placeholder="Fatura için ünvan veya ad soyad" />
                                <small class="text-muted">Firma adı ile aynı olabilir</small>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label form-label-custom">Vergi Dairesi</label>
                                <input name="taxOffice" class="form-control form-control-custom" placeholder="Örn: Kadıköy Vergi Dairesi" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label form-label-custom">Vergi No / TC Kimlik No</label>
                                <input name="taxNumber" class="form-control form-control-custom" placeholder="Vergi numarası veya TC kimlik no" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label form-label-custom">Fatura Adresi</label>
                                <textarea name="invoiceAddress" class="form-control form-control-custom" rows="2" placeholder="Fatura gönderilecek tam adres"></textarea>
                            </div>
                        </div>
                        
                        <div class="section-title">
                            <i class="fas fa-file-alt"></i>
                            Belgeler
                </div>
                        
                        <div class="row g-3 mb-4">
                            <div class="col-md-8">
                                <label class="form-label form-label-custom">Yetki Belgeleri / Sigorta Evrakları</label>
                                <div class="file-upload-area" onclick="document.getElementById('documentsInput').click()">
                                    <i class="fas fa-cloud-upload-alt"></i>
                                    <p class="mb-1">Belgeleri buraya sürükleyin veya <span class="btn-link">dosya seçin</span></p>
                                    <small class="text-muted">PDF, JPG, PNG - Birden fazla dosya yükleyebilirsiniz</small>
                </div>
                                <input type="file" name="documents" id="documentsInput" class="d-none" multiple accept=".pdf,.jpg,.jpeg,.png" />
                                <div id="fileList" class="mt-2 small text-muted"></div>
                </div>
                            <div class="col-md-4">
                                <div class="requirements-box h-100">
                                    <h5><i class="fas fa-info-circle"></i> Gerekli Belgeler</h5>
                                    <ul>
                                        <li>K Yetki Belgesi</li>
                                        <li>Vergi Levhası</li>
                                        <li>Sigorta Poliçesi</li>
                                        <li>Araç Ruhsatları</li>
                                    </ul>
                </div>
                </div>
                </div>
                        
                        <div class="section-title">
                            <i class="fas fa-shield-check"></i>
                            Sözleşme ve Onaylar
                        </div>
                        
                        <div class="mb-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="kvkkAccept" required />
                                <label class="form-check-label" for="kvkkAccept">
                                    <strong>Kişisel Verilerin Korunması Kanunu</strong> kapsamında kişisel verilerimin işlenmesini kabul ediyorum.
                                </label>
                            </div>
                            <div class="form-check mt-3">
                                <input class="form-check-input" type="checkbox" id="contractAccept" required />
                                <label class="form-check-label" for="contractAccept">
                                    <strong>Firma Sözleşmesi</strong>'ni okudum, anladım ve kabul ediyorum.
                                </label>
                            </div>
                        </div>
                        
                        <div class="text-center">
                            <button type="submit" class="btn btn-carrier-submit" id="submitBtn">
                                <i class="fas fa-paper-plane"></i>
                                Başvuruyu Gönder
                            </button>
                            <p class="mt-3 text-muted small">
                                Başvurunuz 24-48 saat içinde incelenecek ve onaylandığında e-posta ile bilgilendirileceksiniz.
                            </p>
                </div>
                    </form>
                    
                    <div class="text-center mt-4 pt-4 border-top">
                        <p class="text-muted mb-0">
                            Zaten kayıtlı mısınız? <a href="@Url.Action("Login", "CarrierAccount")" class="text-decoration-none" style="color: #f97316; font-weight: 600;">Giriş Yapın</a>
                        </p>
                </div>
                </div>
                </div>
        </div>
    </div>
</section>

<script>
    // Dosya yükleme
    document.getElementById('documentsInput').addEventListener('change', function(e) {
        const fileList = document.getElementById('fileList');
        const files = e.target.files;
        if (files.length > 0) {
            let html = '<strong>Seçilen dosyalar:</strong><br>';
            for (let i = 0; i < files.length; i++) {
                html += '<i class="fas fa-file me-1"></i>' + files[i].name + '<br>';
            }
            fileList.innerHTML = html;
        }
    });
    
    // Şifre eşleşme kontrolü
    const password = document.getElementById('password');
    const passwordConfirm = document.getElementById('passwordConfirm');
    const submitBtn = document.getElementById('submitBtn');
    
    function validatePasswords() {
        if (password.value && passwordConfirm.value) {
            if (password.value !== passwordConfirm.value) {
                passwordConfirm.setCustomValidity('Şifreler eşleşmiyor');
                passwordConfirm.classList.add('is-invalid');
            } else {
                passwordConfirm.setCustomValidity('');
                passwordConfirm.classList.remove('is-invalid');
                passwordConfirm.classList.add('is-valid');
            }
        }
    }
    
    password.addEventListener('input', validatePasswords);
    passwordConfirm.addEventListener('input', validatePasswords);
    
    // Form gönderim kontrolü
    document.querySelector('form').addEventListener('submit', function(e) {
        if (password.value !== passwordConfirm.value) {
            e.preventDefault();
            alert('Şifreler eşleşmiyor. Lütfen kontrol edin.');
            return false;
        }
    });
</script>
