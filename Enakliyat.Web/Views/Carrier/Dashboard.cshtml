@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-4 mb-4">
    <!-- Welcome Card -->
    <div class="col-12">
        <div class="carrier-card">
            <div class="carrier-card-body" style="background: linear-gradient(135deg, #18181b 0%, #27272a 100%); border-radius: 12px;">
                <div class="row align-items-center">
                    <div class="col-lg-8">
                        <h3 class="text-white mb-2">Merhaba, @ViewBag.CarrierName! 👋</h3>
                        <p class="text-white text-opacity-75 mb-3 mb-lg-0">
                            Bugün <strong>@ViewBag.NewLeadsWeek</strong> yeni talep sizi bekliyor. Hemen teklif verin ve işinizi büyütün!
                        </p>
                    </div>
                    <div class="col-lg-4 text-lg-end">
                        <a href="@Url.Action("Leads", "Carrier")" class="btn btn-carrier-primary">
                            <i class="fas fa-bullhorn me-2"></i>Talepleri Gör
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Stats -->
    <div class="col-lg-3 col-md-6">
        <div class="carrier-stat-card">
            <div class="carrier-stat-card-icon">
                <i class="fas fa-file-invoice"></i>
            </div>
            <div class="carrier-stat-card-value">@ViewBag.TotalOffers</div>
            <div class="carrier-stat-card-label">Toplam Teklif</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="carrier-stat-card blue">
            <div class="carrier-stat-card-icon">
                <i class="fas fa-hourglass-half"></i>
            </div>
            <div class="carrier-stat-card-value">@ViewBag.PendingOffers</div>
            <div class="carrier-stat-card-label">Bekleyen Teklif</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="carrier-stat-card green">
            <div class="carrier-stat-card-icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="carrier-stat-card-value">@ViewBag.AcceptedOffers</div>
            <div class="carrier-stat-card-label">Kabul Edilen</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="carrier-stat-card purple">
            <div class="carrier-stat-card-icon">
                <i class="fas fa-trophy"></i>
            </div>
            <div class="carrier-stat-card-value">@ViewBag.CompletedMoves</div>
            <div class="carrier-stat-card-label">Tamamlanan İş</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Left Column -->
    <div class="col-xl-8">
        <!-- Performance -->
        <div class="carrier-card mb-4">
            <div class="carrier-card-header">
                <h3 class="carrier-card-title">Performans Özeti</h3>
            </div>
            <div class="carrier-card-body">
                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="text-center">
                            <div class="d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px; background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border-radius: 50%;">
                                <i class="fas fa-star text-warning fs-2"></i>
                            </div>
                            <div class="fs-3 fw-bold">
                                @if (ViewBag.AverageRating != null)
                                {
                                    @(((double)ViewBag.AverageRating).ToString("0.0"))
                                }
                                else
                                {
                                    @: -
                                }
                            </div>
                            <div class="text-muted small">Ortalama Puan</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-center">
                            <div class="d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px; background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%); border-radius: 50%;">
                                <i class="fas fa-comment-alt text-primary fs-2"></i>
                            </div>
                            <div class="fs-3 fw-bold">@ViewBag.ReviewCount</div>
                            <div class="text-muted small">Toplam Değerlendirme</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-center">
                            <div class="d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px; background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%); border-radius: 50%;">
                                <i class="fas fa-calendar-check text-success fs-2"></i>
                            </div>
                            <div class="fs-3 fw-bold">@ViewBag.AcceptedReservations</div>
                            <div class="text-muted small">Aktif Rezervasyon</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Quick Actions -->
        <div class="carrier-card">
            <div class="carrier-card-header">
                <h3 class="carrier-card-title">Hızlı İşlemler</h3>
            </div>
            <div class="carrier-card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <a href="@Url.Action("Leads", "Carrier")" class="d-flex align-items-center p-3 rounded-3 text-decoration-none" style="background: #f4f4f5; transition: all 0.2s;">
                            <div class="me-3" style="width: 48px; height: 48px; background: linear-gradient(135deg, #f97316 0%, #fb923c 100%); border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-bullhorn text-white"></i>
                            </div>
                            <div>
                                <div class="fw-bold text-dark">Yeni Talepleri Gör</div>
                                <div class="text-muted small">@ViewBag.NewLeadsWeek yeni talep</div>
                            </div>
                            <i class="fas fa-chevron-right text-muted ms-auto"></i>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a href="@Url.Action("Offers", "Carrier")" class="d-flex align-items-center p-3 rounded-3 text-decoration-none" style="background: #f4f4f5; transition: all 0.2s;">
                            <div class="me-3" style="width: 48px; height: 48px; background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%); border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-file-invoice-dollar text-white"></i>
                            </div>
                            <div>
                                <div class="fw-bold text-dark">Tekliflerimi Yönet</div>
                                <div class="text-muted small">@ViewBag.PendingOffers bekleyen teklif</div>
                            </div>
                            <i class="fas fa-chevron-right text-muted ms-auto"></i>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a href="@Url.Action("Reservations", "Carrier")" class="d-flex align-items-center p-3 rounded-3 text-decoration-none" style="background: #f4f4f5; transition: all 0.2s;">
                            <div class="me-3" style="width: 48px; height: 48px; background: linear-gradient(135deg, #22c55e 0%, #4ade80 100%); border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-calendar-check text-white"></i>
                            </div>
                            <div>
                                <div class="fw-bold text-dark">Rezervasyonlar</div>
                                <div class="text-muted small">@ViewBag.AcceptedReservations aktif</div>
                            </div>
                            <i class="fas fa-chevron-right text-muted ms-auto"></i>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a href="@Url.Action("Profile", "Carrier")" class="d-flex align-items-center p-3 rounded-3 text-decoration-none" style="background: #f4f4f5; transition: all 0.2s;">
                            <div class="me-3" style="width: 48px; height: 48px; background: linear-gradient(135deg, #8b5cf6 0%, #a78bfa 100%); border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-user-cog text-white"></i>
                            </div>
                            <div>
                                <div class="fw-bold text-dark">Profili Düzenle</div>
                                <div class="text-muted small">Firma bilgilerinizi güncelleyin</div>
                            </div>
                            <i class="fas fa-chevron-right text-muted ms-auto"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Right Column -->
    <div class="col-xl-4">
        <!-- Revenue -->
        <div class="carrier-card mb-4">
            <div class="carrier-card-header">
                <h3 class="carrier-card-title">Haftalık Gelir</h3>
            </div>
            <div class="carrier-card-body">
                <div class="text-center py-3">
                    <div class="mb-3">
                        <div class="d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px; background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%); border-radius: 50%;">
                            <i class="fas fa-lira-sign text-white fs-1"></i>
                        </div>
                    </div>
                    <div class="text-muted small mb-1">Son 7 Günde Kapora</div>
                    <div class="fw-bold fs-2 text-success mb-2">@ViewBag.WeeklyDepositAmount?.ToString("N0") ₺</div>
                    <div class="text-muted small">
                        <i class="fas fa-receipt me-1"></i>@ViewBag.WeeklyDepositCount ödeme
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Tips -->
        <div class="carrier-card">
            <div class="carrier-card-header">
                <h3 class="carrier-card-title">💡 İpuçları</h3>
            </div>
            <div class="carrier-card-body">
                <ul class="list-unstyled mb-0">
                    <li class="d-flex align-items-start mb-3">
                        <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                        <span class="small">Hızlı yanıt veren firmalar %40 daha fazla iş alıyor</span>
                    </li>
                    <li class="d-flex align-items-start mb-3">
                        <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                        <span class="small">Detaylı açıklama ile teklifleriniz öne çıkıyor</span>
                    </li>
                    <li class="d-flex align-items-start mb-3">
                        <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                        <span class="small">Profil fotoğrafı ve belgeler güven oluşturuyor</span>
                    </li>
                    <li class="d-flex align-items-start">
                        <i class="fas fa-check-circle text-success me-2 mt-1"></i>
                        <span class="small">Olumlu müşteri yorumları sıralamayı yükseltiyor</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>
