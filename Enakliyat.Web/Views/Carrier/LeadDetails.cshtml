@{
    ViewData["Title"] = "Nakliyeci - Talep Detayı";
    var request = (Enakliyat.Domain.MoveRequest)ViewBag.Request;
    var offers = (IEnumerable<Enakliyat.Domain.Offer>)ViewBag.ExistingOffers;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-1">Talep #@request.Id</h3>
            <div class="text-muted small">
                @(request.User?.Email ?? request.CustomerName) · @request.CreatedAt.ToLocalTime().ToString("g")
            </div>
        </div>
        <div>
            <a asp-action="Leads" class="btn btn-sm btn-outline-secondary">← Taleplere dön</a>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h5 class="card-title mb-3">İş Bilgileri</h5>
                    <dl class="row small mb-0">
                        <dt class="col-4">Durum</dt>
                        <dd class="col-8 mb-1">@request.Status</dd>
                        <dt class="col-4">Taşıma Tipi</dt>
                        <dd class="col-8 mb-1">@request.MoveType</dd>
                        <dt class="col-4">Tarih</dt>
                        <dd class="col-8 mb-1">@request.MoveDate.ToLocalTime().ToString("g")</dd>
                        <dt class="col-4">Müşteri Adı</dt>
                        <dd class="col-8 mb-1">@request.CustomerName</dd>
                        <dt class="col-4">Telefon</dt>
                        <dd class="col-8 mb-1">@request.PhoneNumber</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h5 class="card-title mb-3">Adres Bilgileri</h5>
                    <dl class="row small mb-0">
                        <dt class="col-4">Nereden</dt>
                        <dd class="col-8 mb-1">@request.FromAddress</dd>
                        <dt class="col-4">Nereye</dt>
                        <dd class="col-8 mb-1">@request.ToAddress</dd>
                    </dl>
                </div>
            </div>
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-2">Notlar</h5>
                    <div class="small text-muted">@request.Notes</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title mb-3">Teklif Ver</h5>
                    <form asp-action="CreateOffer" method="post" class="small" id="offerForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="moveRequestId" value="@request.Id" />
                        <div class="mb-2">
                            <label class="form-label form-label-sm">Teklif Tutarı (TL)</label>
                            <input type="number" step="100" min="0" name="price" class="form-control form-control-sm" required />
                        </div>
                        <div class="mb-2">
                            <label class="form-label form-label-sm">Not (opsiyonel)</label>
                            <textarea name="note" rows="3" class="form-control form-control-sm"></textarea>
                        </div>
                        <button type="submit" class="btn btn-sm btn-primary" id="submitOfferBtn">
                            <span class="submit-text">
                                <i class="fas fa-paper-plane me-1"></i>Teklif Gönder
                            </span>
                            <span class="loading-text" style="display: none;">
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                Gönderiliyor...
                            </span>
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title mb-3">Mevcut Teklifler</h5>
                    <div class="table-responsive">
                        <table class="table table-sm table-hover align-middle mb-0 small">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Firma</th>
                                    <th>Fiyat</th>
                                    <th>Durum</th>
                                </tr>
                            </thead>
                            <tbody>
                            @if (!offers.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-2 small">Bu talep için henüz teklif yok.</td>
                                </tr>
                            }
                            else
                            {
                                var index = 1;
                                foreach (var o in offers)
                                {
                                    <tr>
                                        <td>@index</td>
                                        <td>@(o.Carrier?.Name ?? "-")</td>
                                        <td>@o.Price.ToString("N0") TL</td>
                                        <td>@o.Status</td>
                                    </tr>
                                    index++;
                                }
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Form submit loading state
        const offerForm = document.getElementById('offerForm');
        const submitOfferBtn = document.getElementById('submitOfferBtn');
        if (offerForm && submitOfferBtn) {
            offerForm.addEventListener('submit', function() {
                const submitText = submitOfferBtn.querySelector('.submit-text');
                const loadingText = submitOfferBtn.querySelector('.loading-text');
                if (submitText && loadingText) {
                    submitText.style.display = 'none';
                    loadingText.style.display = 'inline';
                    submitOfferBtn.disabled = true;
                }
            });
        }
    </script>
}
