@model List<Enakliyat.Domain.OfferTemplate>
@{
    ViewData["Title"] = "Teklif Şablonları";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Teklif Şablonları</h2>
    <button class="btn btn-admin-primary" data-bs-toggle="modal" data-bs-target="#createTemplateModal">
        <i class="fas fa-plus me-2"></i>Yeni Şablon
    </button>
</div>

<div class="admin-card">
    <div class="admin-card-body">
        <div class="row g-3">
            @foreach (var template in Model)
            {
                <div class="col-md-6">
                    <div class="card @(template.IsDefault ? "border-primary" : "")">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0">@template.Name @(template.IsDefault ? "(Varsayılan)" : "")</h5>
                                @if (template.IsDefault)
                                {
                                    <span class="badge bg-primary">Varsayılan</span>
                                }
                            </div>
                            <p class="text-muted small">@(template.Description ?? "-")</p>
                            <div class="small">
                                <div><strong>Base:</strong> @(template.BasePrice?.ToString("N2") ?? "-") TL</div>
                                <div><strong>Km başına:</strong> @(template.PricePerKm?.ToString("N2") ?? "-") TL</div>
                                <div><strong>Oda başına:</strong> @(template.PricePerRoom?.ToString("N2") ?? "-") TL</div>
                                <div><strong>Kat başına:</strong> @(template.PricePerFloor?.ToString("N2") ?? "-") TL</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Create Template Modal -->
<div class="modal fade" id="createTemplateModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Yeni Teklif Şablonu</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CreateOfferTemplate" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Şablon Adı *</label>
                        <input name="name" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Açıklama</label>
                        <textarea name="description" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Base Fiyat (TL)</label>
                            <input type="number" name="basePrice" step="0.01" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Km Başına (TL)</label>
                            <input type="number" name="pricePerKm" step="0.01" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Oda Başına (TL)</label>
                            <input type="number" name="pricePerRoom" step="0.01" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Kat Başına (TL)</label>
                            <input type="number" name="pricePerFloor" step="0.01" class="form-control" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Not Şablonu</label>
                        <textarea name="noteTemplate" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="isDefault" id="isDefault" />
                        <label class="form-check-label" for="isDefault">Varsayılan Şablon</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-admin-primary">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

