@model Enakliyat.Web.Models.MoveRequestViewModel

@{
    ViewData["Title"] = "Evden Eve Nakliyat | Güvenilir Nakliye Firmaları";
    Layout = "_Layout";
}

<style>
    /* ===== HERO SECTION ===== */
    .hero-section {
        background: linear-gradient(135deg, #0052CC 0%, #0747A6 50%, #003366 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        position: relative;
        overflow: hidden;
        padding: 2rem 0;
        width: 100%;
        max-width: 100vw;
    }
    
    .hero-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="rgba(255,255,255,0.03)" d="M0,96L48,112C96,128,192,160,288,186.7C384,213,480,235,576,213.3C672,192,768,128,864,128C960,128,1056,192,1152,208C1248,224,1344,192,1392,176L1440,160L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path></svg>') no-repeat bottom;
        background-size: cover;
    }
    
    .hero-floating-shapes {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        pointer-events: none;
    }
    
    .hero-shape {
        position: absolute;
        background: rgba(255,255,255,0.05);
        border-radius: 50%;
    }
    
    .hero-shape-1 {
        width: 300px;
        height: 300px;
        top: -100px;
        right: -100px;
    }
    
    .hero-shape-2 {
        width: 200px;
        height: 200px;
        bottom: 100px;
        left: -50px;
    }
    
    .hero-shape-3 {
        width: 150px;
        height: 150px;
        top: 50%;
        right: 20%;
    }
    
    /* Mobilde shape'leri gizle - kayma yapıyor */
    @@media (max-width: 767.98px) {
        .hero-shape-1,
        .hero-shape-2,
        .hero-shape-3 {
            display: none;
        }
    }
    
    .hero-content {
        position: relative;
        z-index: 2;
    }
    
    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(10px);
        color: #fff;
        padding: 0.5rem 1.25rem;
        border-radius: 50px;
        font-size: 0.9rem;
        font-weight: 500;
        margin-bottom: 1.5rem;
        border: 1px solid rgba(255,255,255,0.2);
    }
    
    .hero-badge i {
        color: #FFD700;
    }
    
    .hero-title {
        font-size: 3.5rem;
        font-weight: 800;
        color: #fff;
        line-height: 1.15;
        margin-bottom: 1.5rem;
    }
    
    .hero-title span {
        color: #FFD700;
    }
    
    .hero-subtitle {
        font-size: 1.25rem;
        color: rgba(255,255,255,0.85);
        margin-bottom: 2rem;
        line-height: 1.7;
    }
    
    .hero-features {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        margin-bottom: 2rem;
    }
    
    .hero-feature {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: rgba(255,255,255,0.9);
        font-weight: 500;
    }
    
    .hero-feature-icon {
        width: 32px;
        height: 32px;
        background: rgba(255,255,255,0.15);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.875rem;
    }
    
    .hero-feature-icon i {
        color: #4ADE80;
    }
    
    /* ===== QUOTE FORM ===== */
    .quote-form-card {
        background: #fff;
        border-radius: 24px;
        box-shadow: 0 25px 80px rgba(0,0,0,0.25);
        overflow: hidden;
        position: relative;
        z-index: 3;
        width: 100%;
        max-width: 100%;
    }
    
    .quote-form-header {
        background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
        padding: 1.5rem 2rem;
        border-bottom: 1px solid #e2e8f0;
    }
    
    .quote-form-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 0.25rem;
    }
    
    .quote-form-subtitle {
        font-size: 0.9rem;
        color: #64748b;
    }
    
    .quote-tabs {
        display: flex;
        background: #f1f5f9;
        border-radius: 12px;
        padding: 4px;
        margin: 1.5rem 2rem 0;
    }
    
    .quote-tab {
        flex: 1;
        padding: 0.875rem 1rem;
        border: none;
        background: transparent;
        color: #64748b;
        font-weight: 600;
        font-size: 0.875rem;
        border-radius: 10px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }
    
    .quote-tab:hover {
        color: #0052CC;
    }
    
    .quote-tab.active {
        background: #fff;
        color: #0052CC;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    
    .quote-form-body {
        padding: 2rem;
    }
    
    .form-floating-custom {
        position: relative;
        margin-bottom: 1rem;
    }
    
    .form-control-custom {
        width: 100%;
        padding: 1rem 1rem 1rem 3rem;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: #f8fafc;
    }
    
    .form-control-custom:focus {
        border-color: #0052CC;
        background: #fff;
        box-shadow: 0 0 0 4px rgba(0,82,204,0.1);
        outline: none;
    }
    
    .form-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        pointer-events: none;
    }
    
    .btn-quote-submit {
        width: 100%;
        padding: 1rem;
        background: linear-gradient(135deg, #FF6B35 0%, #FF8F6B 100%);
        border: none;
        border-radius: 12px;
        color: #fff;
        font-size: 1.1rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
    }
    
    .btn-quote-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 30px rgba(255,107,53,0.4);
    }
    
    .quote-trust-badges {
        display: flex;
        justify-content: center;
        gap: 2rem;
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid #e2e8f0;
    }
    
    .trust-badge {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #64748b;
        font-size: 0.85rem;
    }
    
    .trust-badge i {
        color: #0052CC;
    }
    
    /* ===== SERVICES SECTION ===== */
    .services-section {
        background: #f8fafc;
        padding: 6rem 0;
    }
    
    .service-card {
        background: #fff;
        border-radius: 20px;
        padding: 2rem;
        height: 100%;
        border: 1px solid #e2e8f0;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }
    
    .service-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: linear-gradient(90deg, #0052CC, #4C9AFF);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.4s ease;
    }
    
    .service-card:hover::before {
        transform: scaleX(1);
    }
    
    .service-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 50px rgba(0,82,204,0.15);
        border-color: #0052CC;
    }
    
    .service-icon {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, rgba(0,82,204,0.1) 0%, rgba(76,154,255,0.1) 100%);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        color: #0052CC;
        margin-bottom: 1.5rem;
        transition: all 0.3s ease;
    }
    
    .service-card:hover .service-icon {
        background: linear-gradient(135deg, #0052CC 0%, #4C9AFF 100%);
        color: #fff;
        transform: scale(1.1);
    }
    
    .service-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 0.75rem;
    }
    
    .service-desc {
        color: #64748b;
        font-size: 0.95rem;
        line-height: 1.7;
        margin-bottom: 1.5rem;
    }
    
    .service-features {
        list-style: none;
        padding: 0;
        margin: 0 0 1.5rem 0;
    }
    
    .service-features li {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #475569;
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }
    
    .service-features li i {
        color: #22c55e;
        font-size: 0.75rem;
    }
    
    .service-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #0052CC;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
    }
    
    .service-link:hover {
        gap: 0.75rem;
        color: #003d99;
    }
    
    /* ===== HOW IT WORKS ===== */
    .how-section {
        padding: 6rem 0;
        background: #fff;
    }
    
    .step-card {
        text-align: center;
        padding: 2rem 1.5rem;
        position: relative;
    }
    
    .step-number {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #0052CC 0%, #4C9AFF 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 800;
        color: #fff;
        margin: 0 auto 1.5rem;
        position: relative;
        z-index: 2;
    }
    
    .step-connector {
        position: absolute;
        top: 50px;
        left: calc(50% + 30px);
        width: calc(100% - 60px);
        height: 3px;
        background: linear-gradient(90deg, #0052CC, #4C9AFF);
        z-index: 1;
    }
    
    .step-icon {
        width: 80px;
        height: 80px;
        background: #f1f5f9;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: #0052CC;
        margin: 0 auto 1.5rem;
        transition: all 0.3s ease;
    }
    
    .step-card:hover .step-icon {
        background: linear-gradient(135deg, #0052CC 0%, #4C9AFF 100%);
        color: #fff;
        transform: scale(1.1);
    }
    
    .step-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 0.75rem;
    }
    
    .step-desc {
        color: #64748b;
        font-size: 0.95rem;
        line-height: 1.7;
    }
    
    /* ===== STATS SECTION ===== */
    .stats-section {
        background: linear-gradient(135deg, #0052CC 0%, #0747A6 100%);
        padding: 5rem 0;
        position: relative;
        overflow: hidden;
    }
    
    .stats-section::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 400px;
        height: 400px;
        background: rgba(255,255,255,0.05);
        border-radius: 50%;
    }
    
    .stat-item {
        text-align: center;
        padding: 2rem;
    }
    
    .stat-number {
        font-size: 3.5rem;
        font-weight: 800;
        color: #fff;
        line-height: 1;
        margin-bottom: 0.5rem;
    }
    
    .stat-number span {
        color: #FFD700;
    }
    
    .stat-label {
        color: rgba(255,255,255,0.8);
        font-size: 1.1rem;
        font-weight: 500;
    }
    
    /* ===== ADVANTAGES SECTION ===== */
    .advantages-section {
        padding: 6rem 0;
        background: #f8fafc;
    }
    
    .advantage-card {
        background: #fff;
        border-radius: 16px;
        padding: 2rem;
        height: 100%;
        border: 1px solid #e2e8f0;
        transition: all 0.3s ease;
    }
    
    .advantage-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 40px rgba(0,0,0,0.1);
    }
    
    .advantage-icon {
        width: 56px;
        height: 56px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 1.25rem;
    }
    
    .advantage-icon.blue {
        background: rgba(0,82,204,0.1);
        color: #0052CC;
    }
    
    .advantage-icon.green {
        background: rgba(34,197,94,0.1);
        color: #22c55e;
    }
    
    .advantage-icon.orange {
        background: rgba(255,107,53,0.1);
        color: #FF6B35;
    }
    
    .advantage-icon.purple {
        background: rgba(168,85,247,0.1);
        color: #a855f7;
    }
    
    .advantage-icon.yellow {
        background: rgba(234,179,8,0.1);
        color: #eab308;
    }
    
    .advantage-icon.cyan {
        background: rgba(6,182,212,0.1);
        color: #06b6d4;
    }
    
    .advantage-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 0.5rem;
    }
    
    .advantage-desc {
        color: #64748b;
        font-size: 0.9rem;
        line-height: 1.6;
    }
    
    /* ===== TESTIMONIALS ===== */
    .testimonials-section {
        padding: 6rem 0;
        background: #fff;
    }
    
    .testimonial-card {
        background: #f8fafc;
        border-radius: 20px;
        padding: 2rem;
        height: 100%;
        position: relative;
    }
    
    .testimonial-quote {
        font-size: 3rem;
        color: #0052CC;
        opacity: 0.2;
        position: absolute;
        top: 1rem;
        left: 1.5rem;
    }
    
    .testimonial-rating {
        display: flex;
        gap: 0.25rem;
        margin-bottom: 1rem;
    }
    
    .testimonial-rating i {
        color: #fbbf24;
        font-size: 1rem;
    }
    
    .testimonial-text {
        color: #475569;
        font-size: 1rem;
        line-height: 1.8;
        margin-bottom: 1.5rem;
        font-style: italic;
    }
    
    .testimonial-author {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    
    .author-avatar {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #0052CC 0%, #4C9AFF 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-weight: 700;
        font-size: 1.1rem;
    }
    
    .author-info h5 {
        font-size: 1rem;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 0.25rem;
    }
    
    .author-info span {
        font-size: 0.85rem;
        color: #64748b;
    }
    
    /* ===== FAQ SECTION ===== */
    .faq-section {
        padding: 6rem 0;
        background: #f8fafc;
    }
    
    .accordion-custom {
        border: none;
    }
    
    .accordion-item-custom {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 12px !important;
        margin-bottom: 1rem;
        overflow: hidden;
    }
    
    .accordion-button-custom {
        background: #fff;
        border: none;
        padding: 1.25rem 1.5rem;
        font-size: 1rem;
        font-weight: 600;
        color: #1e293b;
        box-shadow: none !important;
    }
    
    .accordion-button-custom:not(.collapsed) {
        background: #f8fafc;
        color: #0052CC;
    }
    
    .accordion-button-custom::after {
        background-size: 16px;
    }
    
    .accordion-body-custom {
        padding: 0 1.5rem 1.5rem;
        color: #64748b;
        line-height: 1.8;
    }
    
    /* ===== BLOG SECTION ===== */
    .blog-section {
        padding: 6rem 0;
        background: #fff;
    }
    
    .blog-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
        transition: all 0.3s ease;
        height: 100%;
    }
    
    .blog-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 40px rgba(0,0,0,0.1);
    }
    
    .blog-image {
        height: 200px;
        background: linear-gradient(135deg, #0052CC 0%, #4C9AFF 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        color: rgba(255,255,255,0.3);
    }
    
    .blog-content {
        padding: 1.5rem;
    }
    
    .blog-category {
        display: inline-block;
        background: rgba(0,82,204,0.1);
        color: #0052CC;
        padding: 0.25rem 0.75rem;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
    }
    
    .blog-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 0.5rem;
        line-height: 1.4;
    }
    
    .blog-excerpt {
        color: #64748b;
        font-size: 0.9rem;
        line-height: 1.6;
        margin-bottom: 1rem;
    }
    
    .blog-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        color: #94a3b8;
        font-size: 0.85rem;
    }
    
    /* ===== CTA SECTION ===== */
    .cta-section {
        background: linear-gradient(135deg, #FF6B35 0%, #FF8F6B 100%);
        padding: 5rem 0;
        position: relative;
        overflow: hidden;
    }
    
    .cta-section::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -10%;
        width: 400px;
        height: 400px;
        background: rgba(255,255,255,0.1);
        border-radius: 50%;
    }
    
    .cta-title {
        font-size: 2.5rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 1rem;
    }
    
    .cta-subtitle {
        color: rgba(255,255,255,0.9);
        font-size: 1.1rem;
        margin-bottom: 2rem;
    }
    
    /* ===== RESPONSIVE ===== */
    @@media (max-width: 991.98px) {
        html, body {
            max-width: 100vw;
            overflow-x: hidden;
        }
        
        .hero-section {
            min-height: auto;
            padding: 3rem 0;
            width: 100%;
            max-width: 100vw;
        }
        
        .hero-title {
            font-size: 2.5rem;
        }
        
        .quote-form-card {
            margin: 0 1rem;
        }
        
        .quote-tabs {
            flex-wrap: wrap;
            margin-left: 1rem;
            margin-right: 1rem;
            width: calc(100% - 2rem);
            max-width: 100%;
        }
        
        .quote-tab {
            flex: 1 1 45%;
        }
        
        .step-connector {
            display: none;
        }
        
        .container {
            padding-left: 1rem;
            padding-right: 1rem;
            max-width: 100%;
        }
    }
    
    @@media (max-width: 767.98px) {
        html, body {
            max-width: 100vw;
            overflow-x: hidden;
            width: 100%;
        }
        
        .hero-section {
            padding: 1.5rem 0;
            width: 100%;
            max-width: 100vw;
        }
        
        .hero-title {
            font-size: 2rem;
            word-wrap: break-word;
            overflow-wrap: break-word;
        }
        
        .hero-content {
            padding: 0 1rem;
        }
        
        .hero-features {
            flex-direction: column;
            gap: 1rem;
        }
        
        .quote-form-card {
            margin: 0 0.75rem;
            border-radius: 16px;
        }
        
        .quote-form-header {
            padding: 1rem 1.25rem;
        }
        
        .quote-tabs {
            margin: 1rem 1rem 0;
            width: calc(100% - 2rem);
            max-width: 100%;
        }
        
        .quote-trust-badges {
            flex-direction: column;
            gap: 1rem;
        }
        
        .stat-number {
            font-size: 2.5rem;
        }
        
        .container {
            padding-left: 0.75rem;
            padding-right: 0.75rem;
            max-width: 100%;
        }
        
        .row {
            margin-left: 0;
            margin-right: 0;
        }
        
        [class*="col-"] {
            padding-left: 0.5rem;
            padding-right: 0.5rem;
        }
        
        section {
            overflow-x: hidden;
            width: 100%;
            max-width: 100vw;
        }
    }
    
    /* Location suggestions */
    .location-suggestions {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        z-index: 100;
        max-height: 300px;
        overflow-y: auto;
        margin-top: 4px;
    }
    
    .location-suggestion-item {
        padding: 0.875rem 1rem;
        cursor: pointer;
        border-bottom: 1px solid #f1f5f9;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    
    .location-suggestion-item:last-child {
        border-bottom: none;
    }
    
