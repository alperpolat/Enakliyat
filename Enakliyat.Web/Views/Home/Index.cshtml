@section Scripts {
    <script>
        async function searchLocation(term) {
            const response = await fetch(`/Home/SearchLocation?term=${encodeURIComponent(term)}`);
            if (!response.ok) return [];
            return await response.json();
        }

        function setupLocationAutocomplete(inputId, suggestionsId, cityHiddenId, districtHiddenId, neighborhoodHiddenId) {
            const input = document.getElementById(inputId);
            const suggestions = document.getElementById(suggestionsId);
            const cityInput = document.getElementById(cityHiddenId);
            const districtInput = document.getElementById(districtHiddenId);
            const neighborhoodInput = document.getElementById(neighborhoodHiddenId);

            if (!input || !suggestions || !cityInput || !districtInput || !neighborhoodInput) return;

            let currentTimeout = null;

            input.addEventListener('input', function () {
                const term = input.value.trim();
                cityInput.value = '';
                districtInput.value = '';
                neighborhoodInput.value = '';
                suggestions.innerHTML = '';

                if (term.length < 2) {
                    return;
                }

                if (currentTimeout) {
                    clearTimeout(currentTimeout);
                }

                currentTimeout = setTimeout(async () => {
                    const results = await searchLocation(term);
                    suggestions.innerHTML = '';

                    results.forEach(r => {
                        const item = document.createElement('button');
                        item.type = 'button';
                        item.className = 'list-group-item list-group-item-action';
                        item.textContent = r.display ?? r.Display;
                        item.addEventListener('click', function () {
                            input.value = item.textContent;
                            cityInput.value = r.cityId ?? r.CityId;
                            districtInput.value = r.districtId ?? r.DistrictId;
                            neighborhoodInput.value = r.neighborhoodId ?? r.NeighborhoodId;
                            suggestions.innerHTML = '';
                        });
                        suggestions.appendChild(item);
                    });
                }, 250);
            });

            document.addEventListener('click', function (e) {
                if (!suggestions.contains(e.target) && e.target !== input) {
                    suggestions.innerHTML = '';
                }
            });
        }

        document.addEventListener('DOMContentLoaded', function () {
            setupLocationAutocomplete('fromLocationText', 'fromLocationSuggestions', 'fromCityId', 'fromDistrictId', 'fromNeighborhoodId');
            setupLocationAutocomplete('toLocationText', 'toLocationSuggestions', 'toCityId', 'toDistrictId', 'toNeighborhoodId');
            setupLocationAutocomplete('fromLocationTextPartial', 'fromLocationSuggestionsPartial', 'fromCityIdPartial', 'fromDistrictIdPartial', 'fromNeighborhoodIdPartial');
            setupLocationAutocomplete('toLocationTextPartial', 'toLocationSuggestionsPartial', 'toCityIdPartial', 'toDistrictIdPartial', 'toNeighborhoodIdPartial');
            setupLocationAutocomplete('fromLocationTextOffice', 'fromLocationSuggestionsOffice', 'fromCityIdOffice', 'fromDistrictIdOffice', 'fromNeighborhoodIdOffice');
            setupLocationAutocomplete('toLocationTextOffice', 'toLocationSuggestionsOffice', 'toCityIdOffice', 'toDistrictIdOffice', 'toNeighborhoodIdOffice');
            setupLocationAutocomplete('fromLocationTextStorage', 'fromLocationSuggestionsStorage', 'fromCityIdStorage', 'fromDistrictIdStorage', 'fromNeighborhoodIdStorage');
            setupLocationAutocomplete('toLocationTextStorage', 'toLocationSuggestionsStorage', 'toCityIdStorage', 'toDistrictIdStorage', 'toNeighborhoodIdStorage');
            setupLocationAutocomplete('fromLocationTextInternational', 'fromLocationSuggestionsInternational', 'fromCityIdInternational', 'fromDistrictIdInternational', 'fromNeighborhoodIdInternational');
            setupLocationAutocomplete('toLocationTextInternational', 'toLocationSuggestionsInternational', 'toCityIdInternational', 'toDistrictIdInternational', 'toNeighborhoodIdInternational');
        });
    </script>
}
