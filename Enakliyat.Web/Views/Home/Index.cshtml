@model Enakliyat.Web.Models.MoveRequestViewModel

@{
    ViewData["Title"] = "Evden Eve Nakliyat Teklif Al";
}

<!-- HERO -->
<div class="py-5 border-bottom mb-4" style="background-color:#f5f7fb;">
    <div class="container-xxl p-3 p-lg-5">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h1 class="display-4 fw-bolder mb-3 text-body-emphasis" style="letter-spacing:-0.02em;">
                    <span class="d-block">
                        <span style="color:#1a73e8;">Evden</span>
                        <span style="color:#34a853;">eve</span>
                        <span style="color:#fbbc05;">nakliyat</span>
                        <span style="color:#ea4335;">için</span>
                    </span>
                    <span class="d-block text-primary">
                        <span style="color:#34a853;">tek</span>
                        <span style="color:#1a73e8;">form,</span>
                        <span style="color:#ea4335;">onlarca</span>
                        <span style="color:#fbbc05;">teklif.</span>
                    </span>
                </h1>
                <p class="fs-5 text-body-secondary mb-4">
                    Türkiye genelindeki onaylı nakliyecilerden dakikalar içinde fiyat teklifi al.
                    Taşınma detaylarını gir, firmaları puan ve yorumlarına göre karşılaştır, en uygununu seç.
                </p>
                <ul class="list-unstyled mb-4 text-body-secondary">
                    <li class="mb-2"><i class="fa fa-check text-theme me-2"></i> Onaylı ve puanlı firmalar</li>
                    <li class="mb-2"><i class="fa fa-check text-theme me-2"></i> Fotoğraflı talep oluşturma</li>
                    <li class="mb-2"><i class="fa fa-check text-theme me-2"></i> %10 kapora ile güvenli rezervasyon</li>
                </ul>
                <a href="#quote-form" class="btn btn-theme fw-semibold px-4 py-2">
                    Hemen ücretsiz teklif al
                </a>
            </div>
            <div class="col-lg-6 d-none d-lg-block text-center">
                <img src="~/img/3.jpg" alt="Evden eve nakliyat" class="img-fluid rounded-4 shadow" />
            </div>
        </div>
    </div>
</div>

<!-- QUOTE FORM -->
<div id="quote-form" class="py-5" style="background-color:#ffffff;">
