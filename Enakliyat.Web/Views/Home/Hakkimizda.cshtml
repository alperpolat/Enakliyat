@{
    ViewData["Title"] = "Hakkımızda";
}

<style>
    .about-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        padding: 5rem 0;
        position: relative;
        overflow: hidden;
    }
    
    .about-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 70%;
        height: 150%;
        background: radial-gradient(circle, rgba(59,130,246,0.1) 0%, transparent 60%);
    }
    
    .about-hero h1 {
        font-size: 3rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 1.5rem;
    }
    
    .about-hero p {
        font-size: 1.25rem;
        color: rgba(255,255,255,0.8);
        max-width: 700px;
    }
    
    .about-section {
        padding: 5rem 0;
    }
    
    .about-card {
        background: #fff;
        border-radius: 16px;
        padding: 2rem;
        height: 100%;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        border: 1px solid #e2e8f0;
        transition: all 0.3s;
    }
    
    .about-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 40px rgba(0,0,0,0.1);
    }
    
    .about-card-icon {
        width: 64px;
        height: 64px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 1.5rem;
    }
    
    .about-card h3 {
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: 0.75rem;
    }
    
    .about-card p {
        color: #64748b;
        margin: 0;
        line-height: 1.7;
    }
    
    .stats-section {
        background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
        padding: 4rem 0;
    }
    
    .stat-item {
        text-align: center;
        color: #fff;
    }
    
    .stat-value {
        font-size: 3rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
    }
    
    .stat-label {
        font-size: 1rem;
        opacity: 0.9;
    }
    
    .team-section {
        background: #f8fafc;
        padding: 5rem 0;
    }
    
    .section-title {
        font-size: 2rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 1rem;
        text-align: center;
    }
    
    .section-subtitle {
        color: #64748b;
        text-align: center;
        max-width: 600px;
        margin: 0 auto 3rem;
        font-size: 1.1rem;
    }
    
    .timeline {
        position: relative;
        padding-left: 2rem;
    }
    
    .timeline::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 2px;
        background: #e2e8f0;
    }
    
    .timeline-item {
        position: relative;
        padding-bottom: 2rem;
    }
    
    .timeline-item::before {
        content: '';
        position: absolute;
        left: -2rem;
        top: 0.25rem;
        width: 14px;
        height: 14px;
        background: #3b82f6;
        border-radius: 50%;
        margin-left: -6px;
    }
    
    .timeline-year {
        font-weight: 700;
        color: #3b82f6;
        margin-bottom: 0.25rem;
    }
    
    .timeline-title {
        font-weight: 600;
        color: #0f172a;
        margin-bottom: 0.5rem;
    }
    
    .timeline-desc {
        color: #64748b;
        font-size: 0.9375rem;
    }
    
    .values-section {
        padding: 5rem 0;
    }
    
    .value-item {
        display: flex;
        align-items: flex-start;
        gap: 1.5rem;
        margin-bottom: 2rem;
    }
    
    .value-icon {
        width: 56px;
        height: 56px;
        min-width: 56px;
        background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.25rem;
    }
    
    .value-content h4 {
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 0.5rem;
    }
    
    .value-content p {
        color: #64748b;
        margin: 0;
        line-height: 1.7;
    }
</style>

<!-- Hero -->
<section class="about-hero">
    <div class="container-xxl px-3 px-lg-5 position-relative">
        <h1>Hakkımızda</h1>
        <p>
            Nakliye360, 2024 yılında Türkiye'nin nakliyat sektörünü dijitalleştirmek ve 
            müşterilere güvenilir, şeffaf bir taşınma deneyimi sunmak amacıyla kurulmuştur.
        </p>
    </div>
</section>

<!-- Mission & Vision -->
<section class="about-section">
    <div class="container-xxl px-3 px-lg-5">
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="about-card">
                    <div class="about-card-icon" style="background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%); color: #1d4ed8;">
                        <i class="fas fa-bullseye"></i>
                    </div>
                    <h3>Misyonumuz</h3>
                    <p>
                        Türkiye'deki tüm taşınma süreçlerini dijitalleştirerek, müşterilerin 
                        güvenilir nakliyecilere kolayca ulaşmasını, şeffaf fiyatlandırma ile 
                        en uygun teklifleri almasını ve stressiz bir taşınma deneyimi yaşamasını sağlamak.
                    </p>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="about-card">
                    <div class="about-card-icon" style="background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%); color: #16a34a;">
                        <i class="fas fa-eye"></i>
                    </div>
                    <h3>Vizyonumuz</h3>
                    <p>
                        Türkiye'nin en büyük ve en güvenilir online nakliyat platformu olmak. 
                        Her taşınma talebinin dakikalar içinde onlarca onaylı firmadan teklif aldığı, 
                        müşteri memnuniyetinin en üst düzeyde olduğu bir ekosistem oluşturmak.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stats -->
<section class="stats-section">
    <div class="container-xxl px-3 px-lg-5">
        <div class="row g-4">
            <div class="col-md-3 col-6">
                <div class="stat-item">
                    <div class="stat-value">81</div>
                    <div class="stat-label">İl Genelinde Hizmet</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-item">
                    <div class="stat-value">1000+</div>
                    <div class="stat-label">Onaylı Nakliyeci</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-item">
                    <div class="stat-value">50K+</div>
                    <div class="stat-label">Tamamlanan Taşınma</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-item">
                    <div class="stat-value">4.8</div>
                    <div class="stat-label">Müşteri Puanı</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Values -->
<section class="values-section">
    <div class="container-xxl px-3 px-lg-5">
        <h2 class="section-title">Değerlerimiz</h2>
        <p class="section-subtitle">
            Nakliye360 olarak her zaman müşteri memnuniyetini ve güvenliği ön planda tutuyoruz.
        </p>
        
        <div class="row">
            <div class="col-lg-6">
                <div class="value-item">
                    <div class="value-icon">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <div class="value-content">
                        <h4>Güvenilirlik</h4>
                        <p>
                            Platformumuzdaki tüm nakliyeciler titiz bir onay sürecinden geçer. 
                            Yetki belgeleri, sigorta poliçeleri ve geçmiş performansları kontrol edilir.
                        </p>
                    </div>
                </div>
                <div class="value-item">
                    <div class="value-icon" style="background: linear-gradient(135deg, #f97316 0%, #fb923c 100%);">
                        <i class="fas fa-eye"></i>
                    </div>
                    <div class="value-content">
                        <h4>Şeffaflık</h4>
                        <p>
                            Gizli ücret yok, sürpriz maliyet yok. Tüm teklifler net fiyatlarla sunulur. 
                            Gerçek müşteri yorumları ile bilinçli karar verin.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="value-item">
                    <div class="value-icon" style="background: linear-gradient(135deg, #22c55e 0%, #4ade80 100%);">
                        <i class="fas fa-headset"></i>
                    </div>
                    <div class="value-content">
                        <h4>Müşteri Odaklılık</h4>
                        <p>
                            7/24 müşteri desteği ile yanınızdayız. Her aşamada sorularınızı 
                            yanıtlıyor, sorunlarınızı çözüyoruz.
                        </p>
                    </div>
                </div>
                <div class="value-item">
                    <div class="value-icon" style="background: linear-gradient(135deg, #8b5cf6 0%, #a78bfa 100%);">
                        <i class="fas fa-rocket"></i>
                    </div>
                    <div class="value-content">
                        <h4>Yenilikçilik</h4>
                        <p>
                            Teknoloji ile nakliyat sektörünü dönüştürüyoruz. 
                            Sürekli geliştirilen platformumuz ile en iyi deneyimi sunuyoruz.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section style="background: #f1f5f9; padding: 4rem 0;">
    <div class="container-xxl px-3 px-lg-5 text-center">
        <h2 class="mb-3" style="font-weight: 800; color: #0f172a;">Hemen Teklif Alın</h2>
        <p class="text-muted mb-4" style="max-width: 500px; margin: 0 auto;">
            Güvenilir nakliyecilerden dakikalar içinde teklif almak için hemen başlayın.
        </p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-5" style="border-radius: 999px;">
            <i class="fas fa-paper-plane me-2"></i>Teklif Al
        </a>
    </div>
</section>

