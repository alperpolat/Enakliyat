@model Enakliyat.Web.Models.UserRequestDetailsViewModel

@{
    ViewData["Title"] = "Talep Detayı";
}

<div class="container py-4">
    <h3 class="mb-3">Talep Detayı</h3>

    <dl class="row mb-4">
        <dt class="col-sm-3">Oluşturma Tarihi</dt>
        <dd class="col-sm-9">@Model.Request.CreatedAt.ToLocalTime().ToString("f")</dd>

        <dt class="col-sm-3">Taşıma Tipi</dt>
        <dd class="col-sm-9">@Model.Request.MoveType</dd>

        <dt class="col-sm-3">Nereden</dt>
        <dd class="col-sm-9">@Model.Request.FromAddress</dd>

        <dt class="col-sm-3">Nereye</dt>
        <dd class="col-sm-9">@Model.Request.ToAddress</dd>

        <dt class="col-sm-3">Notlar</dt>
        <dd class="col-sm-9">@Model.Request.Notes</dd>
    </dl>

    @if (Model.Photos.Any())
    {
        <div class="mb-4">
            <h5>Eşyalarınızın Fotoğrafları</h5>
            <div class="d-flex flex-wrap gap-2 mt-2">
                @foreach (var photo in Model.Photos)
                {
                    <div class="border rounded" style="width: 140px; height: 140px; overflow: hidden;">
                        <img src="@photo.FilePath" alt="Taşınma fotoğrafı" class="img-fluid" />
                    </div>
                }
            </div>
        </div>
    }

    <form asp-action="Details" method="post" class="mb-3">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Request.Id" />

        <div class="row g-3 align-items-end">
            <div class="col-md-6">
                <label class="form-label" for="statusSelect">Durum</label>
                <select class="form-select" id="statusSelect" name="status">
                    <option value="Yeni" selected="@(Model.Request.Status == "Yeni" ? "selected" : null)">Yeni</option>
                    <option value="Teklif Bekliyor" selected="@(Model.Request.Status == "Teklif Bekliyor" ? "selected" : null)">Teklif Bekliyor</option>
                    <option value="Taşınma Tamamlandı" selected="@(Model.Request.Status == "Taşınma Tamamlandı" ? "selected" : null)">Taşınma Tamamlandı</option>
                    <option value="İptal" selected="@(Model.Request.Status == "İptal" ? "selected" : null)">İptal</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary mt-3 mt-md-0">Durumu Kaydet</button>
            </div>
        </div>
    </form>

    <hr class="my-4" />

    <h4>Bu talebe gelen teklifler</h4>

    <table class="table table-striped table-hover table-sm align-middle mt-2">
        <thead>
            <tr>
                <th>#</th>
                <th>Nakliyeci</th>
                <th>Fiyat</th>
                <th>Durum</th>
                <th>Not</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @if (!Model.Offers.Any())
        {
            <tr>
                <td colspan="6" class="text-center">Bu talep için henüz teklif yok.</td>
            </tr>
        }
        else
        {
            var index = 1;
            foreach (var offer in Model.Offers)
            {
                <tr>
                    <td>@index</td>
                    <td>
                        @(offer.Carrier?.Name ?? "-")<br />
                        @if (offer.Carrier != null && offer.Carrier.ReviewCount > 0)
                        {
                            <small class="text-muted d-block">
                                @offer.Carrier.AverageRating.ToString("0.0") / 5 (@offer.Carrier.ReviewCount değerlendirme)
                            </small>
                        }
                        else if (offer.Carrier != null)
                        {
                            <small class="text-muted d-block">Henüz değerlendirme yok</small>
                        }

                        @if (offer.Carrier != null)
                        {
                            <a class="small" asp-action="CarrierProfile" asp-route-id="@offer.CarrierId">Firma Profili</a>
                        }
                    </td>
                    <td>@offer.Price.ToString("N2") TL</td>
                    <td>@offer.Status</td>
                    <td>@offer.Note</td>
                    <td class="text-end">
                        @if (offer.Status == "Beklemede")
                        {
                            <form asp-action="AcceptOffer" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="offerId" value="@offer.Id" />
                                <input type="hidden" name="moveRequestId" value="@Model.Request.Id" />
                                <button type="submit" class="btn btn-sm btn-success">Bu teklifi kabul et</button>
                            </form>
                        }
                    </td>
                </tr>
                index++;
            }
        }
        </tbody>
    </table>
    <hr class="my-4" />

    @if (Model.ReviewRating.HasValue || Model.CanReview)
    {
        <h4>Firma Değerlendirmesi</h4>

        @if (Model.ReviewRating.HasValue)
        {
            <p>
                <strong>Puanınız:</strong> @Model.ReviewRating.Value / 5<br />
                @if (!string.IsNullOrWhiteSpace(Model.ReviewComment))
                {
                    <strong>Yorumunuz:</strong> @Model.ReviewComment
                }
            </p>
        }
        else if (Model.CanReview && Model.AcceptedCarrierId.HasValue)
        {
            <form asp-action="AddReview" method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="MoveRequestId" value="@Model.Request.Id" />
                <input type="hidden" name="CarrierId" value="@Model.AcceptedCarrierId" />

                <div class="mb-3">
                    <label class="form-label">Puanınız (1-5)</label>
                    <select name="Rating" class="form-select" required>
                        <option value="">Seçiniz</option>
                        @for (int i = 1; i <= 5; i++)
                        {
                            <option value="@i">@i</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Yorumunuz (opsiyonel)</label>
                    <textarea name="Comment" class="form-control" rows="3" maxlength="1000"></textarea>
                </div>

                <button type="submit" class="btn btn-primary">Değerlendirmeyi Kaydet</button>
            </form>
        }
    }

    <a asp-action="Requests" class="btn btn-secondary mt-3">Taleplere Dön</a>
</div>
