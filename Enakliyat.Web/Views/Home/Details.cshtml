@model Enakliyat.Web.Models.UserRequestDetailsViewModel

@{
    ViewData["Title"] = "Talep Detayı";
}

<div class="container-xxl px-3 px-lg-5 py-4">
    <div class="d-flex align-items-center mb-3">
        <div>
            <ol class="breadcrumb mb-1 small text-uppercase">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Ana Sayfa</a></li>
                <li class="breadcrumb-item">
                    @if (Model.MisafirKullaniciId.HasValue)
                    {
                        <a asp-controller="Home" asp-action="TalepTakip" asp-route-t="@Model.MisafirKullaniciId.Value">Taleplerim</a>
                    }
                    else
                    {
                        <a asp-action="Requests">Taleplerim</a>
                    }
                </li>
                <li class="breadcrumb-item active">Talep Detayı</li>
            </ol>
            <h3 class="mb-0">Talep Detayı</h3>
        </div>
    </div>

    <div class="row gx-4 gy-3">
        <div class="col-xl-8">
            <div class="card mb-3 shadow-sm border-0">
                <div class="card-header d-flex align-items-center bg-none fw-semibold">
                    <div class="me-2 rounded-circle bg-theme text-theme-color d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                        <i class="fa fa-truck"></i>
                    </div>
                    <div class="flex-fill">
                        <div>@Model.Request.MoveType</div>
                        <div class="small text-body text-opacity-50">Oluşturma: @Model.Request.CreatedAt.ToLocalTime().ToString("f")</div>
                    </div>
                    <span class="badge rounded-pill @(Model.Request.Status.Contains("Tamamlandı") ? "bg-success" : Model.Request.Status.Contains("İptal") ? "bg-danger" : "bg-warning text-dark")">
                        @Model.Request.Status
                    </span>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <div class="small text-body text-opacity-50 text-uppercase">Nereden</div>
                            <div class="fw-semibold">@Model.Request.FromAddress</div>
                        </div>
                        <div class="col-md-6">
                            <div class="small text-body text-opacity-50 text-uppercase">Nereye</div>
                            <div class="fw-semibold">@Model.Request.ToAddress</div>
                        </div>
                    </div>
                    <div class="row g-3 mb-3 small">
                        <div class="col-sm-6 col-lg-4">
                            <div class="small text-body text-opacity-50 text-uppercase">Ad Soyad</div>
                            <div class="fw-semibold">@Model.Request.CustomerName</div>
                        </div>
                        <div class="col-sm-6 col-lg-4">
                            <div class="small text-body text-opacity-50 text-uppercase">Telefon</div>
                            <div class="fw-semibold">@Model.Request.PhoneNumber</div>
                        </div>
                        <div class="col-sm-6 col-lg-4">
                            <div class="small text-body text-opacity-50 text-uppercase">E-posta</div>
                            <div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.Request.Email) ? "—" : Model.Request.Email)</div>
                        </div>
                        <div class="col-sm-6 col-lg-4">
                            <div class="small text-body text-opacity-50 text-uppercase">Taşınma tarihi</div>
                            <div class="fw-semibold">@Model.Request.MoveDate.ToString("dd.MM.yyyy")</div>
                        </div>
                        <div class="col-sm-6 col-lg-4">
                            <div class="small text-body text-opacity-50 text-uppercase">Oda tipi</div>
                            <div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.Request.RoomType) ? "—" : Model.Request.RoomType)</div>
                        </div>
                        <div class="col-sm-6 col-lg-4">
                            <div class="small text-body text-opacity-50 text-uppercase">Çıkış katı</div>
                            <div class="fw-semibold">@(Model.Request.FromFloor.HasValue ? Model.Request.FromFloor.Value.ToString() : "—")</div>
                        </div>
                        <div class="col-sm-6 col-lg-4">
                            <div class="small text-body text-opacity-50 text-uppercase">Varış katı</div>
                            <div class="fw-semibold">@(Model.Request.ToFloor.HasValue ? Model.Request.ToFloor.Value.ToString() : "—")</div>
                        </div>
                        <div class="col-sm-6 col-lg-4">
                            <div class="small text-body text-opacity-50 text-uppercase">Çıkış adresinde asansör</div>
                            <div class="fw-semibold">@(Model.Request.FromHasElevator ? "Evet" : "Hayır")</div>
                        </div>
                        <div class="col-sm-6 col-lg-4">
                            <div class="small text-body text-opacity-50 text-uppercase">Varış adresinde asansör</div>
                            <div class="fw-semibold">@(Model.Request.ToHasElevator ? "Evet" : "Hayır")</div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="small text-body text-opacity-50 text-uppercase mb-1">Ek hizmetler</div>
                        @if (Model.SecilenEkHizmetler.Count == 0)
                        {
                            <div class="text-body text-opacity-75">Seçilen ek hizmet yok.</div>
                        }
                        else
                        {
                            <ul class="mb-0 ps-3">
                                @foreach (var ad in Model.SecilenEkHizmetler)
                                {
                                    <li class="fw-semibold">@ad</li>
                                }
                            </ul>
                        }
                    </div>
                    <div class="mb-2">
                        <div class="small text-body text-opacity-50 text-uppercase">Notlar</div>
                        <div class="text-body text-opacity-75">@(string.IsNullOrWhiteSpace(Model.Request.Notes) ? "—" : Model.Request.Notes)</div>
                    </div>
                </div>
            </div>

            @if (Model.Photos.Any())
            {
                <div class="card mb-3 shadow-sm border-0">
                    <div class="card-header d-flex align-items-center bg-none fw-semibold">
                        Eşyalarınızın Fotoğrafları
                    </div>
                    <div class="card-body">
                        <div class="d-flex flex-wrap gap-2 mt-1">
                            @foreach (var photo in Model.Photos)
                            {
                                <div class="border rounded bg-body" style="width: 140px; height: 140px; overflow: hidden;">
                                    <img src="@photo.FilePath" alt="Taşınma fotoğrafı" class="img-fluid w-100 h-100 object-fit-cover" />
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <div class="card mb-3 shadow-sm border-0">
                <div class="card-header d-flex align-items-center bg-none fw-semibold">
                    Talep Durumu
                </div>
                <div class="card-body">
                    <form asp-action="Details" method="post" class="mb-0">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Request.Id" />
                        @if (Model.MisafirKullaniciId.HasValue)
                        {
                            <input type="hidden" name="t" value="@Model.MisafirKullaniciId.Value" />
                        }

                        <div class="row g-3 align-items-end">
                            <div class="col-md-6">
                                <label class="form-label" for="statusSelect">Durum</label>
                                <select class="form-select" id="statusSelect" name="status">
                                    <option value="Yeni" selected="@(Model.Request.Status == "Yeni" ? "selected" : null)">Yeni</option>
                                    <option value="Teklif Bekliyor" selected="@(Model.Request.Status == "Teklif Bekliyor" ? "selected" : null)">Teklif Bekliyor</option>
                                    <option value="Taşınma Tamamlandı" selected="@(Model.Request.Status == "Taşınma Tamamlandı" ? "selected" : null)">Taşınma Tamamlandı</option>
                                    <option value="İptal" selected="@(Model.Request.Status == "İptal" ? "selected" : null)">İptal</option>
                                </select>
                            </div>
                            <div class="col-md-auto d-flex align-items-end">
                                <button type="submit" class="btn btn-primary mt-3 mt-md-0 px-4 py-2 fw-semibold rounded-3 shadow-sm">
                                    <i class="fas fa-save me-2"></i>Durumu Kaydet
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card mb-3 shadow-sm border-0">
                <div class="card-header d-flex align-items-center bg-none fw-semibold">
                    Bu talebe gelen teklifler
                </div>
                <div class="card-body">
                    @if (!Model.Offers.Any())
                    {
                        <div class="text-center py-4">
                            <i class="fa fa-inbox fa-2x text-body text-opacity-50 mb-2"></i>
                            <div class="fw-semibold">Bu talep için henüz teklif yok.</div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var offer in Model.Offers.OrderBy(o => o.Price))
                            {
                                var isAccepted = Model.AcceptedCarrierId.HasValue && Model.AcceptedCarrierId.Value == offer.CarrierId && Model.Request.AcceptedOfferId == offer.Id;
                                <div class="border rounded-3 p-3 d-flex flex-column flex-md-row align-items-md-center @(isAccepted ? "border-success" : "border-body border-opacity-25")">
                                    <div class="flex-fill">
                                        <div class="d-flex align-items-center mb-1">
                                            <div class="fw-semibold me-2">@(offer.Carrier?.Name ?? "-")</div>
                                            @if (isAccepted)
                                            {
                                                <span class="badge bg-success rounded-pill">Seçilen Teklif</span>
                                            }
                                            else if (offer.Status == "Beklemede")
                                            {
                                                <span class="badge bg-warning text-dark rounded-pill">Beklemede</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary rounded-pill">@offer.Status</span>
                                            }
                                        </div>
                                        @if (offer.Carrier != null && offer.Carrier.ReviewCount > 0)
                                        {
                                            <div class="small text-body text-opacity-75 mb-1">
                                                <i class="fa fa-star text-warning me-1"></i>
                                                @offer.Carrier.AverageRating.ToString("0.0") / 5 (@offer.Carrier.ReviewCount değerlendirme)
                                            </div>
                                        }
                                        else if (offer.Carrier != null)
                                        {
                                            <div class="small text-body text-opacity-50 mb-1">Henüz değerlendirme yok</div>
                                        }
                                        @if (offer.Carrier != null)
                                        {
                                            <a class="small" asp-action="CarrierProfile" asp-route-id="@offer.CarrierId">Firma Profili</a>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(offer.Note))
                                        {
                                            <div class="small text-body text-opacity-75 mt-2">
                                                <i class="fa fa-sticky-note me-1"></i>@offer.Note
                                            </div>
                                        }
                                    </div>
                                    <div class="text-md-end mt-3 mt-md-0 ms-md-3" style="min-width: 180px;">
                                        <div class="fw-bold fs-5 mb-1">@offer.Price.ToString("N2") TL</div>
                                        @if (offer.Status == "Beklemede")
                                        {
                                            <form asp-action="AcceptOffer" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="offerId" value="@offer.Id" />
                                                <input type="hidden" name="moveRequestId" value="@Model.Request.Id" />
                                                @if (Model.MisafirKullaniciId.HasValue)
                                                {
                                                    <input type="hidden" name="t" value="@Model.MisafirKullaniciId.Value" />
                                                }
                                                <button type="submit" class="btn btn-sm btn-primary fw-semibold shadow-sm">Bu teklifi kabul et</button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            @if (Model.ReviewRating.HasValue || Model.CanReview)
            {
                <div class="card mb-3 shadow-sm border-0">
                    <div class="card-header d-flex align-items-center bg-none fw-semibold">
                        Firma Değerlendirmesi
                    </div>
                    <div class="card-body">
                        @if (Model.ReviewRating.HasValue)
                        {
                            <p class="mb-2">
                                <strong>Puanınız:</strong> @Model.ReviewRating.Value / 5
                            </p>
                            @if (!string.IsNullOrWhiteSpace(Model.ReviewComment))
                            {
                                <p class="mb-0"><strong>Yorumunuz:</strong> @Model.ReviewComment</p>
                            }
                        }
                        else if (Model.CanReview && Model.AcceptedCarrierId.HasValue)
                        {
                            <form asp-action="AddReview" method="post" class="mt-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="MoveRequestId" value="@Model.Request.Id" />
                                <input type="hidden" name="CarrierId" value="@Model.AcceptedCarrierId" />
                                @if (Model.MisafirKullaniciId.HasValue)
                                {
                                    <input type="hidden" name="t" value="@Model.MisafirKullaniciId.Value" />
                                }

                                <div class="mb-3">
                                    <label class="form-label">Puanınız (1-5)</label>
                                    <select name="Rating" class="form-select" required>
                                        <option value="">Seçiniz</option>
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <option value="@i">@i</option>
                                        }
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Yorumunuz (opsiyonel)</label>
                                    <textarea name="Comment" class="form-control" rows="3" maxlength="1000"></textarea>
                                </div>

                                <button type="submit" class="btn btn-primary px-4 fw-semibold rounded-3 shadow-sm">Değerlendirmeyi Kaydet</button>
                            </form>
                        }
                    </div>
                </div>
            }

            @if (Model.Payment != null)
            {
                <div class="card mb-3 shadow-sm border-0">
                    <div class="card-header d-flex align-items-center bg-none fw-semibold">
                        Kapora Ödemesi
                    </div>
                    <div class="card-body">
                        <div class="small text-body text-opacity-50 mb-1">Tutar (Teklifin %10'u)</div>
                        <div class="fw-semibold mb-2">@Model.Payment.Amount.ToString("N2") @Model.Payment.Currency</div>

                        <div class="small text-body text-opacity-50 mb-1">Ödeme Tarihi</div>
                        <div class="mb-2">@Model.Payment.CreatedAt.ToLocalTime().ToString("f")</div>

                        <div class="small text-body text-opacity-50 mb-1">Durum</div>
                        <div>
                            @if (Model.Payment.Status == Enakliyat.Domain.PaymentStatus.Paid)
                            {
                                <span class="badge bg-success">Ödendi</span>
                            }
                            else if (Model.Payment.Status == Enakliyat.Domain.PaymentStatus.Pending)
                            {
                                <span class="badge bg-warning text-dark">Beklemede</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@Model.Payment.Status</span>
                            }
                        </div>
                    </div>
                </div>
            }

            <div class="card shadow-sm border-0">
                <div class="card-body d-flex flex-column">
                    <div class="small text-body text-opacity-50 mb-1">Talep No</div>
                    <div class="fw-semibold mb-3">@Model.Request.Id</div>

                    @if (Model.AcceptedCarrierId.HasValue)
                    {
                        var kazanan = Model.Offers.FirstOrDefault(o => o.CarrierId == Model.AcceptedCarrierId.Value && o.Id == Model.Request.AcceptedOfferId);
                        if (kazanan != null)
                        {
                            <div class="small text-body text-opacity-50 mb-1">İşi Alan Firma</div>
                            <div class="fw-semibold mb-2">
                                @kazanan.Carrier?.Name
                            </div>
                            <a asp-action="CarrierProfile" asp-route-id="@kazanan.CarrierId" class="small mb-3 text-decoration-none">Firma Profilini Gör</a>
                        }
                    }

                    @if (Model.MisafirKullaniciId.HasValue)
                    {
                        <a asp-controller="Home" asp-action="TalepTakip" asp-route-t="@Model.MisafirKullaniciId.Value" class="btn btn-outline-secondary fw-semibold mt-auto">Taleplerime Dön</a>
                    }
                    else
                    {
                        <a asp-action="Requests" class="btn btn-outline-secondary fw-semibold mt-auto">Taleplere Dön</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
