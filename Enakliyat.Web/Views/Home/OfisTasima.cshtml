@{
    ViewData["Title"] = "Ofis Taşıma | Kurumsal Nakliyat Hizmeti";
    Layout = "_Layout";
}

<style>
    .service-hero {
        background: linear-gradient(135deg, #1e3a5f 0%, #0d2137 100%);
        padding: 6rem 0 4rem;
        position: relative;
        overflow: hidden;
    }
    
    .service-hero::before {
        content: '';
        position: absolute;
        top: 0;
        right: 0;
        width: 50%;
        height: 100%;
        background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><rect x="60" y="10" width="35" height="35" rx="5" fill="rgba(255,255,255,0.02)"/><rect x="70" y="55" width="25" height="25" rx="5" fill="rgba(255,255,255,0.03)"/></svg>');
        background-size: cover;
    }
    
    .service-hero-content { position: relative; z-index: 2; }
    
    .service-breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
    }
    
    .service-breadcrumb a {
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        font-size: 0.9rem;
    }
    
    .service-breadcrumb span { color: rgba(255,255,255,0.5); }
    .service-breadcrumb .current { color: #4CAF50; }
    
    .service-hero-title {
        font-size: 3rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 1.5rem;
        line-height: 1.2;
    }
    
    .service-hero-title span { color: #4CAF50; }
    
    .service-hero-desc {
        font-size: 1.2rem;
        color: rgba(255,255,255,0.85);
        margin-bottom: 2rem;
        line-height: 1.7;
        max-width: 600px;
    }
    
    .service-hero-stats {
        display: flex;
        gap: 3rem;
        margin-top: 2rem;
    }
    
    .hero-stat-number {
        font-size: 2.5rem;
        font-weight: 800;
        color: #4CAF50;
    }
    
    .hero-stat-label {
        font-size: 0.9rem;
        color: rgba(255,255,255,0.7);
    }
    
    .service-hero-card {
        background: #fff;
        border-radius: 20px;
        padding: 2rem;
        box-shadow: 0 25px 60px rgba(0,0,0,0.3);
    }
    
    .service-hero-card h4 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 1rem;
    }
    
    .service-quick-form .form-control {
        padding: 0.875rem 1rem 0.875rem 2.75rem;
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        font-size: 0.95rem;
        margin-bottom: 0.75rem;
        background: #f8fafc;
    }
    
    .service-quick-form .form-control:focus {
        border-color: #1e3a5f;
        background: #fff;
        box-shadow: 0 0 0 3px rgba(30,58,95,0.1);
    }
    
    .service-quick-form .form-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        z-index: 5;
    }
    
    .service-quick-form .btn-submit {
        width: 100%;
        padding: 1rem;
        background: linear-gradient(135deg, #1e3a5f 0%, #0d2137 100%);
        border: none;
        border-radius: 10px;
        color: #fff;
        font-weight: 700;
        font-size: 1rem;
        transition: all 0.3s;
    }
    
    .service-quick-form .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(30,58,95,0.35);
    }
    
    .office-feature-grid {
        padding: 5rem 0;
        background: #f8fafc;
    }
    
    .office-feature {
        background: #fff;
        border-radius: 16px;
        padding: 2rem;
        height: 100%;
        border: 1px solid #e2e8f0;
        transition: all 0.3s;
        text-align: center;
    }
    
    .office-feature:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 40px rgba(0,0,0,0.1);
        border-color: #1e3a5f;
    }
    
    .office-feature-icon {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, rgba(30,58,95,0.1) 0%, rgba(30,58,95,0.05) 100%);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        color: #1e3a5f;
        margin: 0 auto 1.25rem;
        transition: all 0.3s;
    }
    
    .office-feature:hover .office-feature-icon {
        background: linear-gradient(135deg, #1e3a5f 0%, #0d2137 100%);
        color: #fff;
    }
    
    .office-feature-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 0.5rem;
    }
    
    .office-feature-desc {
        color: #64748b;
        font-size: 0.9rem;
        line-height: 1.6;
    }
    
    .process-section { padding: 5rem 0; background: #fff; }
    
    .timeline {
        position: relative;
        padding: 2rem 0;
    }
    
    .timeline::before {
        content: '';
        position: absolute;
        left: 50%;
        top: 0;
        bottom: 0;
        width: 3px;
        background: linear-gradient(180deg, #1e3a5f, #4CAF50);
        transform: translateX(-50%);
    }
    
    .timeline-item {
        display: flex;
        align-items: center;
        margin-bottom: 3rem;
    }
    
    .timeline-item:nth-child(odd) { flex-direction: row-reverse; }
    
    .timeline-content {
        width: 45%;
        background: #f8fafc;
        padding: 1.5rem;
        border-radius: 12px;
    }
    
    .timeline-number {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #1e3a5f 0%, #4CAF50 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-weight: 800;
        font-size: 1.25rem;
        margin: 0 2.5%;
        position: relative;
        z-index: 2;
    }
    
    .pricing-section {
        padding: 5rem 0;
        background: linear-gradient(135deg, #1e3a5f 0%, #0d2137 100%);
    }
    
    .pricing-card {
        background: #fff;
        border-radius: 16px;
        padding: 2rem;
        text-align: center;
        height: 100%;
    }
    
    .pricing-icon {
        width: 70px;
        height: 70px;
        background: rgba(30,58,95,0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        font-size: 1.75rem;
        color: #1e3a5f;
    }
    
    .pricing-title { font-size: 1.25rem; font-weight: 700; color: #1e293b; margin-bottom: 0.5rem; }
    .pricing-desc { color: #64748b; font-size: 0.9rem; margin-bottom: 1.5rem; }
    .pricing-range { font-size: 1.75rem; font-weight: 800; color: #1e3a5f; margin-bottom: 0.25rem; }
    .pricing-note { font-size: 0.8rem; color: #94a3b8; }
    
    .service-cta { padding: 5rem 0; background: #f8fafc; }
    
    .cta-card {
        background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
        border-radius: 20px;
        padding: 3rem;
        position: relative;
        overflow: hidden;
    }
    
    .cta-card::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 300px;
        height: 300px;
        background: rgba(255,255,255,0.1);
        border-radius: 50%;
    }
    
    .cta-card h3 { font-size: 2rem; font-weight: 800; color: #fff; margin-bottom: 1rem; }
    .cta-card p { font-size: 1.1rem; color: rgba(255,255,255,0.9); margin-bottom: 2rem; }
    
    .service-faq { padding: 5rem 0; background: #fff; }
    
    .accordion-item-custom {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 12px !important;
        margin-bottom: 1rem;
        overflow: hidden;
    }
    
    .accordion-button-custom {
        background: #fff;
        border: none;
        padding: 1.25rem 1.5rem;
        font-size: 1rem;
        font-weight: 600;
        color: #1e293b;
        box-shadow: none !important;
    }
    
    .accordion-button-custom:not(.collapsed) { background: #f8fafc; color: #1e3a5f; }
    .accordion-body-custom { padding: 0 1.5rem 1.5rem; color: #64748b; line-height: 1.8; }
    
    @@media (max-width: 991.98px) {
        .service-hero-title { font-size: 2.25rem; }
        .timeline::before { left: 30px; }
        .timeline-item, .timeline-item:nth-child(odd) { flex-direction: column; }
        .timeline-content { width: 100%; margin-left: 60px; }
        .timeline-number { position: absolute; left: 5px; }
    }
    
    @@media (max-width: 767.98px) {
        .service-hero { padding: 4rem 0 3rem; }
        .service-hero-title { font-size: 1.75rem; }
        .service-hero-stats { flex-wrap: wrap; gap: 1.5rem; }
    }
</style>

<!-- SERVICE HERO -->
<section class="service-hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7 mb-5 mb-lg-0">
                <div class="service-hero-content" data-aos="fade-right">
                    <div class="service-breadcrumb">
                        <a asp-controller="Home" asp-action="Index"><i class="fas fa-home me-1"></i> Ana Sayfa</a>
                        <span>/</span>
                        <a href="#">Hizmetler</a>
                        <span>/</span>
                        <span class="current">Ofis Taşıma</span>
                    </div>
                    
                    <h1 class="service-hero-title">
                        Profesyonel <span>Ofis Taşıma</span> Hizmeti
                    </h1>
                    
                    <p class="service-hero-desc">
                        İşinizi aksatmadan ofisinizi taşıyoruz. IT ekipmanları, mobilyalar ve arşivleriniz 
                        güvenle yeni adresinize ulaşır. Hafta sonu ve gece taşıma seçenekleri.
                    </p>
                    
                    <div class="d-flex flex-wrap gap-3 mb-4">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-white-custom">
                            <i class="fas fa-calculator me-2"></i>
                            Ücretsiz Teklif Al
                        </a>
                        <a href="tel:08501234567" class="btn btn-outline-custom" style="border-color: rgba(255,255,255,0.5); color: #fff;">
                            <i class="fas fa-phone me-2"></i>
                            0850 123 45 67
                        </a>
                    </div>
                    
                    <div class="service-hero-stats">
                        <div class="hero-stat">
                            <div class="hero-stat-number">5K+</div>
                            <div class="hero-stat-label">Kurumsal Taşınma</div>
                        </div>
                        <div class="hero-stat">
                            <div class="hero-stat-number">%99</div>
                            <div class="hero-stat-label">Zamanında Teslimat</div>
                        </div>
                        <div class="hero-stat">
                            <div class="hero-stat-number">24/7</div>
                            <div class="hero-stat-label">Destek</div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-5" data-aos="fade-left">
                <div class="service-hero-card">
                    <h4><i class="fas fa-building me-2" style="color: #1e3a5f;"></i> Ofis Taşıma Teklifi</h4>
                    <div class="service-quick-form">
                        <a asp-controller="Home" asp-action="Offers" asp-route-moveType="Office" class="btn-submit d-inline-flex align-items-center justify-content-center text-decoration-none w-100">
                            <i class="fas fa-paper-plane me-2"></i>
                            Ücretsiz Teklif Al
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- OFFICE FEATURES -->
<section class="office-feature-grid">
    <div class="container">
        <div class="text-center mb-5" data-aos="fade-up">
            <span class="section-badge">
                <i class="fas fa-briefcase"></i>
                Kurumsal Çözümler
            </span>
            <h2 class="section-title">Ofis Taşımada <span>Neler Sunuyoruz?</span></h2>
        </div>
        
        <div class="row g-4">
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="0">
                <div class="office-feature">
                    <div class="office-feature-icon"><i class="fas fa-server"></i></div>
                    <h4 class="office-feature-title">IT Ekipman Taşıma</h4>
                    <p class="office-feature-desc">Sunucu, bilgisayar ve ağ ekipmanlarınız özel koruma ile taşınır</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="100">
                <div class="office-feature">
                    <div class="office-feature-icon"><i class="fas fa-archive"></i></div>
                    <h4 class="office-feature-title">Arşiv Taşıma</h4>
                    <p class="office-feature-desc">Evraklarınız düzenli ve güvenli şekilde taşınır, kaybolma riski sıfır</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="200">
                <div class="office-feature">
                    <div class="office-feature-icon"><i class="fas fa-moon"></i></div>
                    <h4 class="office-feature-title">Gece & Hafta Sonu</h4>
                    <p class="office-feature-desc">İş günlerini etkilememek için esnek taşıma saatleri</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="300">
                <div class="office-feature">
                    <div class="office-feature-icon"><i class="fas fa-tools"></i></div>
                    <h4 class="office-feature-title">Montaj Hizmeti</h4>
                    <p class="office-feature-desc">Mobilya ve sistemleriniz yeni ofisinizde kuruluma hazır</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="400">
                <div class="office-feature">
                    <div class="office-feature-icon"><i class="fas fa-project-diagram"></i></div>
                    <h4 class="office-feature-title">Proje Yönetimi</h4>
                    <p class="office-feature-desc">Dedicated proje yöneticisi ile süreç takibi</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="500">
                <div class="office-feature">
                    <div class="office-feature-icon"><i class="fas fa-shield-alt"></i></div>
                    <h4 class="office-feature-title">Tam Sigorta</h4>
                    <p class="office-feature-desc">Tüm ekipman ve mobilyalar sigorta kapsamında</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="600">
                <div class="office-feature">
                    <div class="office-feature-icon"><i class="fas fa-broom"></i></div>
                    <h4 class="office-feature-title">Temizlik Hizmeti</h4>
                    <p class="office-feature-desc">Eski ve yeni ofiste profesyonel temizlik</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="700">
                <div class="office-feature">
                    <div class="office-feature-icon"><i class="fas fa-boxes"></i></div>
                    <h4 class="office-feature-title">Malzeme Desteği</h4>
                    <p class="office-feature-desc">Koliler ve paketleme malzemeleri ücretsiz sağlanır</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- PRICING -->
<section class="pricing-section">
    <div class="container">
        <div class="text-center mb-5" data-aos="fade-up">
            <span class="section-badge" style="background: rgba(255,255,255,0.2); color: #fff;">
                <i class="fas fa-tags"></i>
                Fiyatlandırma
            </span>
            <h2 class="section-title" style="color: #fff;">Ofis Taşıma <span style="color: #4CAF50;">Fiyatları</span></h2>
        </div>
        
        <div class="row g-4">
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="0">
                <div class="pricing-card">
                    <div class="pricing-icon"><i class="fas fa-user-tie"></i></div>
                    <h4 class="pricing-title">Küçük Ofis</h4>
                    <p class="pricing-desc">1-5 kişilik ofisler için</p>
                    <div class="pricing-range">₺3.500 - ₺6.000</div>
                    <p class="pricing-note">Şehir içi taşıma</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="100">
                <div class="pricing-card">
                    <div class="pricing-icon"><i class="fas fa-users"></i></div>
                    <h4 class="pricing-title">Orta Ölçekli Ofis</h4>
                    <p class="pricing-desc">5-20 kişilik ofisler için</p>
                    <div class="pricing-range">₺6.000 - ₺15.000</div>
                    <p class="pricing-note">Şehir içi taşıma</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="200">
                <div class="pricing-card">
                    <div class="pricing-icon"><i class="fas fa-building"></i></div>
                    <h4 class="pricing-title">Kurumsal Ofis</h4>
                    <p class="pricing-desc">20+ kişilik ofisler için</p>
                    <div class="pricing-range">₺15.000+</div>
                    <p class="pricing-note">Özel fiyatlandırma</p>
                </div>
            </div>
        </div>
        
        <div class="text-center mt-5" data-aos="fade-up">
            <a asp-controller="Home" asp-action="Index" class="btn btn-white-custom">
                <i class="fas fa-calculator me-2"></i>
                Ücretsiz Keşif Talep Et
            </a>
        </div>
    </div>
</section>

<!-- FAQ -->
<section class="service-faq">
    <div class="container">
        <div class="row">
            <div class="col-lg-4 mb-4 mb-lg-0" data-aos="fade-right">
                <span class="section-badge">
                    <i class="fas fa-question-circle"></i>
                    SSS
                </span>
                <h2 class="section-title">Ofis Taşıma <span>Hakkında</span></h2>
            </div>
            
            <div class="col-lg-8" data-aos="fade-left">
                <div class="accordion" id="officeFaq">
                    <div class="accordion-item accordion-item-custom">
                        <h2 class="accordion-header">
                            <button class="accordion-button accordion-button-custom" type="button" data-bs-toggle="collapse" data-bs-target="#ofaq1">
                                Ofis taşıma ne kadar sürer?
                            </button>
                        </h2>
                        <div id="ofaq1" class="accordion-collapse collapse show" data-bs-parent="#officeFaq">
                            <div class="accordion-body accordion-body-custom">
                                Ofis büyüklüğüne göre değişir. Küçük ofisler genellikle 1 gün, orta ölçekli ofisler 1-2 gün, 
                                büyük kurumsal taşınmalar ise 3-5 gün sürebilir. Hafta sonu taşıma ile iş günleri etkilenmez.
                            </div>
                        </div>
                    </div>
                    
                    <div class="accordion-item accordion-item-custom">
                        <h2 class="accordion-header">
                            <button class="accordion-button accordion-button-custom collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#ofaq2">
                                IT ekipmanlarım güvende mi?
                            </button>
                        </h2>
                        <div id="ofaq2" class="accordion-collapse collapse" data-bs-parent="#officeFaq">
                            <div class="accordion-body accordion-body-custom">
                                Evet, tüm IT ekipmanları (sunucu, bilgisayar, yazıcı vb.) anti-statik malzemelerle paketlenir 
                                ve özel taşıma kasalarında nakledilir. Ayrıca sigorta kapsamındadır.
                            </div>
                        </div>
                    </div>
                    
                    <div class="accordion-item accordion-item-custom">
                        <h2 class="accordion-header">
                            <button class="accordion-button accordion-button-custom collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#ofaq3">
                                Gizli evraklar nasıl taşınıyor?
                            </button>
                        </h2>
                        <div id="ofaq3" class="accordion-collapse collapse" data-bs-parent="#officeFaq">
                            <div class="accordion-body accordion-body-custom">
                                Gizlilik sözleşmesi imzalanır. Evraklar mühürlü kutularda taşınır ve sadece yetkili 
                                personel tarafından teslim alınır. KVKK uyumlu süreç yönetimi uygulanır.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="service-cta">
    <div class="container">
        <div class="cta-card" data-aos="fade-up">
            <div class="row align-items-center">
                <div class="col-lg-8 mb-4 mb-lg-0">
                    <h3>Ofisinizi Taşımaya Hazır mısınız?</h3>
                    <p>Profesyonel ekibimiz size özel çözümler sunmak için hazır.</p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-white-custom">
                        <i class="fas fa-calculator me-2"></i>
                        Teklif Al
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

