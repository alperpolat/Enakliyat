@model Enakliyat.Web.Models.OfferDetailsViewModel

@{
    ViewData["Title"] = "Teklif Formu";
    var vehicleOnly = string.Equals(Model.MoveType, "VehicleOnly", StringComparison.OrdinalIgnoreCase);
}

<style>
    @@import url("https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css");
    .location-suggestions {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        z-index: 100;
        max-height: 300px;
        overflow-y: auto;
        margin-top: 4px;
    }
    .location-suggestion-item {
        padding: 0.875rem 1rem;
        cursor: pointer;
        border-bottom: 1px solid #f1f5f9;
        transition: background 0.2s;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .location-suggestion-item:last-child { border-bottom: none; }
    .location-suggestion-item:hover { background: #f8fafc; }
    .location-suggestion-item i { color: #0052CC; }
</style>

<div class="py-5" style="background-color:#f5f7fb;">
    <div class="container-xxl p-3 p-lg-5" data-move-type="@Model.MoveType">
        <div class="row justify-content-center mb-4">
            <div class="col-12 col-lg-10">
                <h1 class="h4 fw-semibold mb-2">Ücretsiz teklif formu</h1>
                <p class="text-body-secondary mb-0">Taşıma tipi: <strong>@(vehicleOnly ? "Sadece Araç" : Model.MoveType)</strong></p>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-12 col-lg-10">
                <div class="card border-0 shadow-lg rounded-4">
                    <div class="card-body p-4 p-lg-5">
                        <form asp-action="Offers" method="post" enctype="multipart/form-data" id="offerForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="MoveRequestId" />
                            <input type="hidden" asp-for="MoveType" />

                            <div asp-validation-summary="All" class="text-danger small mb-2"></div>

                            <div class="row g-3 g-lg-4">
                                @if (!vehicleOnly)
                                {
                                <div class="col-12">
                                    <label class="form-label">Nereden taşınacak?</label>
                                    <div class="position-relative">
                                        <i class="fas fa-map-marker-alt position-absolute text-muted" style="left:1rem; top:50%; transform:translateY(-50%); z-index:1; pointer-events:none;"></i>
                                        <input type="text" class="form-control form-control-lg ps-5" id="fromLocationText"
                                               value="@Model.FromAddress" placeholder="İl, ilçe veya mahalle arayın..." autocomplete="off" />
                                        <input type="hidden" asp-for="FromCityId" id="fromCityId" />
                                        <input type="hidden" asp-for="FromDistrictId" id="fromDistrictId" />
                                        <input type="hidden" asp-for="FromNeighborhoodId" id="fromNeighborhoodId" />
                                        <div id="fromLocationSuggestions" class="location-suggestions" style="display: none;"></div>
                                    </div>
                                </div>
                                }
                                else
                                {
                                    <input type="hidden" asp-for="FromCityId" id="fromCityId" />
                                    <input type="hidden" asp-for="FromDistrictId" id="fromDistrictId" />
                                    <input type="hidden" asp-for="FromNeighborhoodId" id="fromNeighborhoodId" />
                                }
                                <div class="col-12">
                                    <label class="form-label">@(vehicleOnly ? "Araç nereye gelecek?" : "Nereye taşınacak?")</label>
                                    <div class="position-relative">
                                        <i class="fas fa-flag-checkered position-absolute text-muted" style="left:1rem; top:50%; transform:translateY(-50%); z-index:1; pointer-events:none;"></i>
                                        <input type="text" class="form-control form-control-lg ps-5" id="toLocationText"
                                               value="@Model.ToAddress" placeholder="İl, ilçe veya mahalle arayın..." autocomplete="off" />
                                        <input type="hidden" asp-for="ToCityId" id="toCityId" />
                                        <input type="hidden" asp-for="ToDistrictId" id="toDistrictId" />
                                        <input type="hidden" asp-for="ToNeighborhoodId" id="toNeighborhoodId" />
                                        <div id="toLocationSuggestions" class="location-suggestions" style="display: none;"></div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="CustomerName" class="form-label">İsminiz</label>
                                    <input asp-for="CustomerName" class="form-control form-control-lg" />
                                    <span asp-validation-for="CustomerName" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="PhoneNumber" class="form-label">Telefon numaranız (5xx xxx xx xx)</label>
                                    <input asp-for="PhoneNumber" class="form-control form-control-lg" />
                                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Email" class="form-label">E-posta adresinizi girin</label>
                                    <input asp-for="Email" class="form-control form-control-lg" />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="moveDateRangeDisplay" id="moveDateRangeLabel">@(vehicleOnly ? "Araç Kiralama Tarihi" : "Taşınma tarihi")</label>
                                    <div class="position-relative">
                                        <i class="fas fa-calendar-alt position-absolute text-muted" style="left:1rem; top:50%; transform:translateY(-50%); z-index:2; pointer-events:none;"></i>
                                        <input type="text" class="form-control form-control-lg ps-5" id="moveDateRangeDisplay"
                                               placeholder="@(vehicleOnly ? "Kiralama dönemi seçin" : "Başlangıç ve bitiş seçin")" autocomplete="off" readonly />
                                    </div>
                                    <div class="form-text">Tek gün: aynı güne iki kez tıklayın veya yalnızca bir gün seçip uygulayın.</div>
                                    <input type="hidden" asp-for="MoveDate" id="offerMoveDate" asp-format="{0:yyyy-MM-dd}" />
                                    <input type="hidden" asp-for="MoveDateEnd" id="offerMoveDateEnd" asp-format="{0:yyyy-MM-dd}" />
                                    <span asp-validation-for="MoveDate" class="text-danger"></span>
                                    <span asp-validation-for="MoveDateEnd" class="text-danger"></span>
                                </div>

                                @if (!vehicleOnly)
                                {
                                <div class="col-md-6">
                                    <label asp-for="RoomType" class="form-label" id="roomTypeLabel">Oda tipi seçin</label>
                                    <select asp-for="RoomType" class="form-select form-select-lg" id="roomTypeSelect">
                                        <option value="">Seçiniz</option>
                                        <option>1+1</option>
                                        <option>2+1</option>
                                        <option>3+1</option>
                                        <option>4+1 ve üzeri</option>
                                    </select>
                                </div>

                                <div class="col-md-3">
                                    <label asp-for="FromFloor" class="form-label">Çıkış Katı</label>
                                    <input asp-for="FromFloor" type="number" class="form-control form-control-lg" min="0" />
                                </div>
                                <div class="col-md-3">
                                    <label asp-for="ToFloor" class="form-label">Varış Katı</label>
                                    <input asp-for="ToFloor" type="number" class="form-control form-control-lg" min="0" />
                                </div>

                                <div class="col-md-6 d-flex align-items-end">
                                    <div class="form-check mt-3">
                                        <input class="form-check-input" asp-for="FromHasElevator" />
                                        <label class="form-check-label" asp-for="FromHasElevator">Çıkış adresinde asansör var</label>
                                    </div>
                                </div>
                                <div class="col-md-6 d-flex align-items-end">
                                    <div class="form-check mt-3">
                                        <input class="form-check-input" asp-for="ToHasElevator" />
                                        <label class="form-check-label" asp-for="ToHasElevator">Varış adresinde asansör var</label>
                                    </div>
                                </div>
                                }

                                <div class="col-12">
                                    <label asp-for="Notes" class="form-label" id="notesLabel">@(vehicleOnly ? "Detay" : "Taşınma detaylarını girin")</label>
                                    <textarea asp-for="Notes" class="form-control" rows="4" id="notesTextarea" placeholder="@(vehicleOnly ? "Araç tipi, kasa hacmi, süre, özel istekler vb." : "Eşyaların tarifleri, asansör ihtiyacı, araç yanaşabilme imkanı vb.")"></textarea>
                                    <span asp-validation-for="Notes" class="text-danger"></span>
                                </div>

                                @if (!vehicleOnly)
                                {
                                <div class="col-12">
                                    <label class="form-label">Eşyalarınızın Fotoğrafları (isteğe bağlı)</label>
                                    <input asp-for="Photos" type="file" class="form-control" multiple />
                                </div>
                                }

                                @if (!vehicleOnly && ViewBag.AddOnServices != null)
                                {
                                    <div class="col-12">
                                        <hr />
                                        <h5>Ek Hizmetler</h5>
                                        <div class="row g-2 mt-1">
                                            @foreach (var s in (IEnumerable<Enakliyat.Domain.AddOnService>)ViewBag.AddOnServices)
                                            {
                                                <div class="col-md-4">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" name="SelectedAddOnIds" value="@s.Id" id="addon_@s.Id" />
                                                        <label class="form-check-label" for="addon_@s.Id">
                                                            @s.Name
                                                            @if (s.DefaultPrice.HasValue)
                                                            {
                                                                <span class="text-muted">(@s.DefaultPrice.Value.ToString("N2") TL)</span>
                                                            }
                                                        </label>
                                                    </div>
                                                </div>
                                            }
                                            @if (ViewBag.SadeceAracAddOn != null)
                                            {
                                                var sa = (Enakliyat.Domain.AddOnService)ViewBag.SadeceAracAddOn;
                                                <div class="col-md-4">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" name="SelectedAddOnIds" value="@sa.Id" id="addon_sadece_arac" />
                                                        <label class="form-check-label" for="addon_sadece_arac">
                                                            @sa.Name
                                                            @if (sa.DefaultPrice.HasValue)
                                                            {
                                                                <span class="text-muted">(@sa.DefaultPrice.Value.ToString("N2") TL)</span>
                                                            }
                                                        </label>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }

                                <div class="col-12 d-flex justify-content-end mt-3">
                                    <button type="submit" class="btn btn-primary btn-lg px-4" id="submitBtn">
                                        <span class="submit-text">
                                            <i class="fas fa-paper-plane me-2"></i>Teklifleri Al
                                        </span>
                                        <span class="loading-text" style="display: none;">
                                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                            Gönderiliyor...
                                        </span>
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/tr.js"></script>
    <script>
        (function () {
            const container = document.querySelector('[data-move-type]');
            if (!container) return;

            const moveType = (container.getAttribute('data-move-type') || '').toLowerCase();
            const roomLabel = document.getElementById('roomTypeLabel');
            const roomSelect = document.getElementById('roomTypeSelect');
            const notesLabel = document.getElementById('notesLabel');
            const notesTextarea = document.getElementById('notesTextarea');
            const dateLabel = document.getElementById('moveDateRangeLabel');
            const dateDisplay = document.getElementById('moveDateRangeDisplay');

            if (moveType === 'vehicleonly') {
                if (dateLabel) dateLabel.textContent = 'Araç Kiralama Tarihi';
                if (dateDisplay) dateDisplay.setAttribute('placeholder', 'Kiralama dönemi seçin');
                if (notesLabel) notesLabel.textContent = 'Detay';
                if (notesTextarea) {
                    notesTextarea.setAttribute('placeholder', 'Araç tipi, kasa hacmi, süre, özel istekler vb.');
                }
                return;
            }

            if (!roomLabel || !roomSelect || !notesLabel || !notesTextarea) return;

            let roomText = 'Oda tipi seçin';
            let notesText = 'Taşınma detaylarını girin';
            let notesPlaceholder = 'Eşyaların tarifleri, asansör ihtiyacı, araç yanaşabilme imkanı vb.';

            if (moveType === 'office') {
                roomText = 'Ofis büyüklüğü (m²)';
                notesText = 'Ofis taşınma detaylarını girin';
                notesPlaceholder = 'Çalışan sayısı, oda sayısı, özel ekipman vb.';
            } else if (moveType === 'storage') {
                roomText = 'Depolama süresi';
                notesText = 'Depolanacak eşyalar ve süre';
                notesPlaceholder = 'Hangi eşyalar, yaklaşık hacim ve ne kadar süreyle depolanacağı.';
            } else if (moveType === 'international') {
                roomText = 'Gönderi tipi';
                notesText = 'Uluslararası taşınma detaylarını girin';
                notesPlaceholder = 'Hedef ülke detayları, gümrük bilgileri, özel istekler vb.';
            } else if (moveType === 'partial') {
                roomText = 'Parça eşya türü';
                notesText = 'Eşyaların detaylarını girin';
                notesPlaceholder = 'Koli sayısı, büyük eşyalar (beyaz eşya, mobilya) vb.';
            }

            roomLabel.textContent = roomText;
            notesLabel.textContent = notesText;
            notesTextarea.setAttribute('placeholder', notesPlaceholder);
        })();

        // Form submit loading state
        const offerForm = document.getElementById('offerForm');
        const submitBtn = document.getElementById('submitBtn');
        if (offerForm && submitBtn) {
            offerForm.addEventListener('submit', function () {
                if (window.jQuery) {
                    var $f = window.jQuery(offerForm);
                    if ($f.data('validator') && !$f.valid()) {
                        return;
                    }
                } else if (!offerForm.checkValidity()) {
                    return;
                }
                const submitText = submitBtn.querySelector('.submit-text');
                const loadingText = submitBtn.querySelector('.loading-text');
                if (submitText && loadingText) {
                    submitText.style.display = 'none';
                    loadingText.style.display = 'inline';
                    submitBtn.disabled = true;
                }
            });
        }

        async function searchLocation(term) {
            const response = await fetch(`/Home/SearchLocation?term=${encodeURIComponent(term)}`);
            if (!response.ok) return [];
            return await response.json();
        }

        function setupLocationAutocomplete(inputId, suggestionsId, cityHiddenId, districtHiddenId, neighborhoodHiddenId) {
            const input = document.getElementById(inputId);
            const suggestions = document.getElementById(suggestionsId);
            const cityInput = document.getElementById(cityHiddenId);
            const districtInput = document.getElementById(districtHiddenId);
            const neighborhoodInput = document.getElementById(neighborhoodHiddenId);
            if (!input || !suggestions || !cityInput || !districtInput || !neighborhoodInput) return;

            let currentTimeout = null;
            input.addEventListener('input', function() {
                const term = input.value.trim();
                cityInput.value = '';
                districtInput.value = '';
                neighborhoodInput.value = '';
                if (term.length < 2) {
                    suggestions.style.display = 'none';
                    suggestions.innerHTML = '';
                    return;
                }
                if (currentTimeout) clearTimeout(currentTimeout);
                currentTimeout = setTimeout(async () => {
                    const results = await searchLocation(term);
                    suggestions.innerHTML = '';
                    if (results.length === 0) {
                        suggestions.style.display = 'none';
                        return;
                    }
                    results.forEach(r => {
                        const item = document.createElement('div');
                        item.className = 'location-suggestion-item';
                        item.innerHTML = `<i class="fas fa-map-marker-alt"></i><span>${r.display ?? r.Display}</span>`;
                        item.addEventListener('click', function() {
                            input.value = r.display ?? r.Display;
                            cityInput.value = r.cityId ?? r.CityId;
                            districtInput.value = r.districtId ?? r.DistrictId;
                            neighborhoodInput.value = r.neighborhoodId ?? r.NeighborhoodId;
                            suggestions.style.display = 'none';
                            suggestions.innerHTML = '';
                        });
                        suggestions.appendChild(item);
                    });
                    suggestions.style.display = 'block';
                }, 250);
            });
            document.addEventListener('click', function(e) {
                if (!suggestions.contains(e.target) && e.target !== input) {
                    suggestions.style.display = 'none';
                }
            });
        }

        function offerToYmd(d) {
            var y = d.getFullYear();
            var m = String(d.getMonth() + 1).padStart(2, '0');
            var day = String(d.getDate()).padStart(2, '0');
            return y + '-' + m + '-' + day;
        }

        function offerParseIsoDate(s) {
            if (!s) return null;
            var p = s.trim().split('-');
            if (p.length !== 3) return null;
            var d = new Date(parseInt(p[0], 10), parseInt(p[1], 10) - 1, parseInt(p[2], 10));
            return isNaN(d.getTime()) ? null : d;
        }

        document.addEventListener('DOMContentLoaded', function() {
            if (document.getElementById('fromLocationText')) {
                setupLocationAutocomplete('fromLocationText', 'fromLocationSuggestions', 'fromCityId', 'fromDistrictId', 'fromNeighborhoodId');
            }
            setupLocationAutocomplete('toLocationText', 'toLocationSuggestions', 'toCityId', 'toDistrictId', 'toNeighborhoodId');

            var displayEl = document.getElementById('moveDateRangeDisplay');
            var startHidden = document.getElementById('offerMoveDate');
            var endHidden = document.getElementById('offerMoveDateEnd');
            if (displayEl && startHidden && endHidden && window.flatpickr) {
                var trLocale = window.flatpickr.l10ns.tr
                    ? Object.assign({}, window.flatpickr.l10ns.tr, { rangeSeparator: ' – ' })
                    : { rangeSeparator: ' – ' };
                var startVal = (startHidden.value || '').trim();
                var endVal = (endHidden.value || '').trim();
                var defaultDates = [];
                var d0 = offerParseIsoDate(startVal);
                if (d0) {
                    defaultDates.push(d0);
                    var d1 = offerParseIsoDate(endVal);
                    if (d1 && offerToYmd(d1) !== offerToYmd(d0)) {
                        defaultDates.push(d1);
                    }
                }
                window.flatpickr(displayEl, {
                    mode: 'range',
                    dateFormat: 'd.m.Y',
                    locale: trLocale,
                    allowInput: false,
                    showMonths: window.matchMedia('(min-width: 768px)').matches ? 2 : 1,
                    defaultDate: defaultDates.length ? defaultDates : undefined,
                    onChange: function(selectedDates) {
                        if (!selectedDates.length) {
                            startHidden.value = '';
                            endHidden.value = '';
                            return;
                        }
                        if (selectedDates.length === 1) {
                            startHidden.value = offerToYmd(selectedDates[0]);
                            endHidden.value = '';
                            return;
                        }
                        var a = selectedDates[0];
                        var b = selectedDates[1];
                        startHidden.value = offerToYmd(a);
                        endHidden.value = offerToYmd(a) === offerToYmd(b) ? '' : offerToYmd(b);
                    }
                });
            }
        });
    </script>
}
