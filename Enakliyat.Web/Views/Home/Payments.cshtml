@model IEnumerable<Enakliyat.Domain.Payment>

@{
    ViewData["Title"] = "Ödeme Geçmişim";
}

<div class="container py-4">
    <h3 class="mb-3">Ödeme Geçmişim</h3>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Tarih</th>
                            <th>Tutar</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-3 small">Henüz ödeme kaydınız yok.</td>
                        </tr>
                    }
                    else
                    {
                        var index = 1;
                        foreach (var p in Model)
                        {
                            <tr>
                                <td>@index</td>
                                <td>@p.CreatedAt.ToLocalTime().ToString("g")</td>
                                <td>@p.Amount.ToString("N0") TL</td>
                                <td>@p.Status</td>
                            </tr>
                            index++;
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
