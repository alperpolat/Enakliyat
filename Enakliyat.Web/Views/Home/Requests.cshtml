@model IEnumerable<Enakliyat.Domain.MoveRequest>

@{
    ViewData["Title"] = "Taleplerim";
}

<div class="container-xxl px-3 px-lg-5 py-4">
    <div class="d-flex align-items-center mb-3">
        <div>
            <ol class="breadcrumb mb-1 small text-uppercase">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Ana Sayfa</a></li>
                <li class="breadcrumb-item active">Taleplerim</li>
            </ol>
            <h3 class="mb-0">Taleplerim</h3>
        </div>
    </div>

    <div class="row mb-3 g-2">
        @if (ViewBag.PendingOfferCount != null && ViewBag.PendingOfferCount > 0)
        {
            <div class="col-12 col-lg-6">
                <div class="alert alert-info d-flex align-items-center h-100 mb-0">
                    <i class="fa fa-clock me-2"></i>
                    <div>
                        <strong>@ViewBag.PendingOfferCount</strong> talebiniz için teklifler bekleniyor.
                    </div>
                </div>
            </div>
        }

        @if (ViewBag.AcceptedReservationCount != null && ViewBag.AcceptedReservationCount > 0)
        {
            <div class="col-12 col-lg-6">
                <div class="alert alert-success d-flex align-items-center h-100 mb-0">
                    <i class="fa fa-check-circle me-2"></i>
                    <div>
                        <strong>@ViewBag.AcceptedReservationCount</strong> talebiniz için kabul edilmiş rezervasyonunuz var.
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="fa fa-box-open fa-2x text-body text-opacity-50 mb-2"></i>
                <div class="fw-semibold mb-1">Henüz kayıtlı talep yok.</div>
                <p class="text-body text-opacity-75 mb-3">İlk taşınma talebinizi oluşturarak onaylı nakliyecilerden teklif almaya başlayın.</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-theme fw-semibold">Yeni Talep Oluştur</a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var item in Model.OrderByDescending(x => x.CreatedAt))
            {
                <div class="col-12 col-lg-6 col-xl-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-header bg-none d-flex align-items-center">
                            <div class="me-2 rounded-circle bg-theme text-theme-color d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                <i class="fa fa-truck"></i>
                            </div>
                            <div class="flex-fill">
                                <div class="fw-semibold">@item.MoveType</div>
                                <div class="small text-body text-opacity-50">@item.CreatedAt.ToLocalTime().ToString("g")</div>
                            </div>
                            <span class="badge rounded-pill @(item.Status.Contains("Tamamlandı") ? "bg-success" : item.Status.Contains("İptal") ? "bg-danger" : "bg-warning text-dark")">
                                @item.Status
                            </span>
                        </div>
                        <div class="card-body">
                            <div class="mb-2">
                                <div class="small text-body text-opacity-50 text-uppercase">Nereden</div>
                                <div class="fw-semibold text-truncate" title="@item.FromAddress">@item.FromAddress</div>
                            </div>
                            <div class="mb-2">
                                <div class="small text-body text-opacity-50 text-uppercase">Nereye</div>
                                <div class="fw-semibold text-truncate" title="@item.ToAddress">@item.ToAddress</div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(item.Notes))
                            {
                                <div class="small text-body text-opacity-75 mt-2 text-truncate" title="@item.Notes">
                                    <i class="fa fa-sticky-note me-1"></i>@item.Notes
                                </div>
                            }
                        </div>
                        <div class="card-footer bg-none d-flex align-items-center">
                            <small class="text-body text-opacity-50">
                                Talep No: @item.Id
                            </small>
                            <a class="btn btn-sm btn-theme fw-semibold ms-auto" asp-action="Details" asp-route-id="@item.Id">
                                Detayları Gör
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
