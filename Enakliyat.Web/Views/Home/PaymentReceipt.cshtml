@model Enakliyat.Domain.Payment

@{
    ViewData["Title"] = "Ödeme Dekontu";
    var request = Model.Contract.Offer.MoveRequest;
    var offer = Model.Contract.Offer;
}

<div class="container-xxl px-3 px-lg-5 py-4">
    <div class="d-flex align-items-center mb-3">
        <div>
            <ol class="breadcrumb mb-1 small text-uppercase">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Ana Sayfa</a></li>
                <li class="breadcrumb-item"><a asp-action="Requests">Taleplerim</a></li>
                <li class="breadcrumb-item"><a asp-action="Details" asp-route-id="@request.Id">Talep Detayı</a></li>
                <li class="breadcrumb-item active">Ödeme Dekontu</li>
            </ol>
            <h3 class="mb-0">Ödeme Dekontu</h3>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <div class="row mb-4">
                <div class="col-md-6">
                    <h5 class="fw-semibold mb-3">Ödeme Bilgileri</h5>
                    <dl class="row mb-0 small">
                        <dt class="col-5">Dekont No</dt>
                        <dd class="col-7">@Model.Id</dd>

                        <dt class="col-5">Talep No</dt>
                        <dd class="col-7">@request.Id</dd>

                        <dt class="col-5">Tarih</dt>
                        <dd class="col-7">@Model.CreatedAt.ToLocalTime().ToString("f")</dd>

                        <dt class="col-5">Tutar</dt>
                        <dd class="col-7">@Model.Amount.ToString("N2") @Model.Currency (Teklifin %10'u kapora)</dd>

                        <dt class="col-5">Durum</dt>
                        <dd class="col-7">
                            @if (Model.Status == Enakliyat.Domain.PaymentStatus.Paid)
                            {
                                <span class="badge bg-success">Ödendi</span>
                            }
                            else if (Model.Status == Enakliyat.Domain.PaymentStatus.Pending)
                            {
                                <span class="badge bg-warning text-dark">Beklemede</span>
                            }
                            else if (Model.Status == Enakliyat.Domain.PaymentStatus.Failed)
                            {
                                <span class="badge bg-danger">Başarısız</span>
                            }
                            else if (Model.Status == Enakliyat.Domain.PaymentStatus.Refunded)
                            {
                                <span class="badge bg-secondary">İade Edildi</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@Model.Status</span>
                            }
                        </dd>
                    </dl>
                </div>
                <div class="col-md-6">
                    <h5 class="fw-semibold mb-3">İş Bilgileri</h5>
                    <dl class="row mb-0 small">
                        <dt class="col-5">Taşıma Tipi</dt>
                        <dd class="col-7">@request.MoveType</dd>

                        <dt class="col-5">Nereden</dt>
                        <dd class="col-7">@request.FromAddress</dd>

                        <dt class="col-5">Nereye</dt>
                        <dd class="col-7">@request.ToAddress</dd>

                        <dt class="col-5">Taşınma Tarihi</dt>
                        <dd class="col-7">@request.MoveDate.ToLocalTime().ToString("d")</dd>

                        <dt class="col-5">Toplam Teklif</dt>
                        <dd class="col-7">@offer.Price.ToString("N2") TL</dd>

                        <dt class="col-5">Firma</dt>
                        <dd class="col-7">@offer.Carrier?.Name</dd>
                    </dl>
                </div>
            </div>

            <div class="border-top pt-3 d-flex justify-content-between align-items-center small text-body text-opacity-75">
                <div>
                    Bu dekont, Nakliye360 üzerinden yapılan kapora ödemesini göstermektedir.
                </div>
                <div class="text-end">
                    <a asp-action="Details" asp-route-id="@request.Id" class="btn btn-outline-secondary btn-sm">Talep Detayına Dön</a>
                </div>
            </div>
        </div>
    </div>
</div>
